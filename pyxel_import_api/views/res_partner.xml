<odoo>
    <data>
        <record id="view_partner_form" model="ir.ui.view">
            <field name="name">res.partner.form</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group/group/field[@name='vat']" position="after">
                    <group>
                        <field name="user_ids" invisible="1"/>
                        <button name="generate_token" type="object" string="Generate Token" class="oe_highlight"
                                invisible="user_ids == False"/>
                        <field name="access_token" invisible="user_ids == False" readonly="1"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
