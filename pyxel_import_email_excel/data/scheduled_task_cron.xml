<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_scheduled_task" model="ir.cron">
            <field name="name">Scheduled Task</field>
            <field name="model_id" ref="model_scheduled_task"/>
            <field name="state">code</field>
            <field name="code">model.scheduled_check_import_errors()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.utcnow() + timedelta(days=1)).strftime('%Y-%m-%d 08:00:00')"/>
        </record>

        <record id="ir_cron_scheduled_task_contracts" model="ir.cron">
            <field name="name">Scheduled Task - Check Contract Expiration</field>
            <field name="model_id" ref="model_scheduled_task"/>
            <field name="state">code</field>
            <field name="code">model.scheduled_check_contract_expiration()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall"
                   eval="(datetime.utcnow() + timedelta(days=1)).replace(hour=8, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

        <record id="ir_cron_scheduled_task_containers" model="ir.cron">
            <field name="name">Scheduled Task - Check Containers Status</field>
            <field name="model_id" ref="model_scheduled_task"/>
            <field name="state">code</field>
            <field name="code">model.scheduled_check_containers_status()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall"
                   eval="(datetime.utcnow() + timedelta(days=1)).replace(hour=9, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>