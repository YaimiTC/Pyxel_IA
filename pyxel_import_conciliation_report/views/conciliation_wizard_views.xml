<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pyxel_import_conciliation_wizard_form" model="ir.ui.view">
        <field name="name">pyxel.import.conciliation.wizard.form</field>
        <field name="model">pyxel.import.conciliation.wizard</field>
        <field name="arch" type="xml">
            <form string="Conciliation">
                <group>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="partner_id"/>
                    <field name="contract_to_third"/>
                    <field name="type_conciliation"/>
                    <field name="format_of_report"/>
                </group>
                <footer>
                    <button name="action_generate_report" type="object" string="Confirm" class="oe_highlight"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pyxel_import_conciliation_wizard" model="ir.actions.act_window">
        <field name="name">Conciliation</field>
        <field name="res_model">pyxel.import.conciliation.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pyxel_import_conciliation_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
