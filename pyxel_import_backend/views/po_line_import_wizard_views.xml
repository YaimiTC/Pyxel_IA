<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Vista del wizard -->
  <record id="view_po_line_import_wizard_form" model="ir.ui.view">
    <field name="name">po.line.import.wizard.form</field>
    <field name="model">po.line.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importar líneas a Orden de Compra" create="false" edit="false">
        <sheet>

          <!-- PO destino -->
          <group>
            <field name="purchase_id" required="1" domain="[('state','in',('draft','sent'))]"/>
          </group>

          <!-- Archivo -->
          <group string="Archivo">
            <field name="file_data" filename="file_name" required="1"/>
            <field name="file_name" readonly="1"/>
            <group>
              <field name="sheet_index"/>
              <field name="header_row"/>
            </group>
          </group>

          <!-- Mapeo de columnas (por defecto B,C,D,E en tu layout) -->
          <group string="Mapeo de columnas">
            <group>
              <field name="col_product" placeholder="B" required="1"/>
              <field name="col_uom" placeholder="C" required="1"/>
            </group>
            <group>
              <field name="col_qty" placeholder="D" required="1"/>
              <field name="col_price" placeholder="E" required="1"/>
            </group>
          </group>

          <!-- Opciones de lectura y corte -->
          <group string="Lectura y control">
            <group>
              <field name="stop_at_first_label"
                     help="La tabla se corta antes de la primera etiqueta (IMPORTE EXWORK, GASTO FOB, FLETE, SEGURO u OTROS GASTOS)."/>
              <field name="max_data_rows"
                     help="Límite duro de filas tras el encabezado. Déjalo vacío para no limitar."/>
            </group>
            <group>
              <field name="empty_product_break"
                     help="Corta si detecta N filas consecutivas sin producto."/>
              <field name="strict_numeric"
                     help="Si está activo, fila con cantidad/precio no numéricos genera error; si no, se omite con aviso."/>
            </group>
          </group>

          <!-- Opciones de creación -->
          <group string="Opciones de creación">
            <group>
              <field name="create_missing_products"/>
              <field name="default_product_type"/>
              <field name="default_uom_id"/>
            </group>
            <group>
              <field name="clear_existing_lines"/>
            </group>
          </group>

          <!-- Servicios (recargos) -->
          <group string="Servicios (líneas especiales)">
            <group>
              <field name="product_freight_id"/>
              <field name="product_insurance_id"/>
            </group>
            <group>
              <field name="product_fob_id"/>
              <field name="product_other_id"/>
            </group>
          </group>

          <!-- Resultado -->
          <group string="Resultado" invisible="note ==  False">
            <field name="note" nolabel="1" readonly="1"/>
          </group>

        </sheet>

        <footer>
          <button string="Importar" type="object" name="action_import" class="btn-primary"/>
          <button string="Cancelar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>



  <record id="action_po_line_import_wizard" model="ir.actions.act_window">
    <field name="name">Importar líneas desde Excel</field>
    <field name="res_model">po.line.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="view_id" ref="view_po_line_import_wizard_form"/>
    <field name="target">new</field>
    <field name="context">{'default_purchase_id': active_id}</field>
  </record>

  <record id="purchase_order_form_inherit_import_excel" model="ir.ui.view">
    <field name="name">purchase.order.form.inherit.import.excel</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <header position="inside">
        <button name="%(action_po_line_import_wizard)d"
                type="action"
                string="Importar líneas (Excel)"
                class="oe_highlight"
                invisible="state not in ('draft','sent')"/>
      </header>
    </field>
  </record>

</odoo>
