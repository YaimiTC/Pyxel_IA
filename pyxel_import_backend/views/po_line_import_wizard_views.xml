<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_po_line_import_wizard_form" model="ir.ui.view">
    <field name="name">po.line.import.wizard.form</field>
    <field name="model">po.line.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importar líneas a Orden de Compra">
        <sheet>

          <!-- Orden de compra -->
          <group>
            <field name="purchase_id" required="1"
                   domain="[('state','in',('draft','sent'))]"/>
          </group>

          <!-- Archivo -->
          <group string="Archivo Excel">
            <field name="file_data" filename="file_name" required="1"/>
            <field name="file_name" readonly="1"/>
            <group>
              <field name="sheet_index"/>
            </group>
          </group>

          <notebook>

            <!-- TAB Productos -->
            <page string="Productos">
              <group string="Encabezado / Límites de productos">
                <group>
                  <field name="header_row_products"/>
                  <field name="max_product_rows"/>
                </group>
                <group>
                  <field name="empty_product_break"/>
                  <field name="strict_numeric_products"/>
                </group>
              </group>

              <group string="Columnas en Excel (tabla principal)">
                <group>
                  <field name="col_prod_seq" placeholder="A"/>
                  <field name="col_prod_name" placeholder="B"/>
                  <field name="col_prod_code" placeholder="C"/>
                </group>
                <group>
                  <field name="col_prod_uom" placeholder="D"/>
                  <field name="col_prod_qty" placeholder="E"/>
                  <field name="col_prod_price" placeholder="F"/>
                </group>
              </group>

              <group string="Opciones de creación de producto">
                <group>
                  <field name="create_missing_products"/>
                  <field name="default_product_type"/>
                </group>
                <group>
                  <field name="default_uom_id"/>
                  <field name="clear_existing_lines"/>
                </group>
              </group>
            </page>

            <!-- TAB Servicios -->
            <page string="Servicios">
              <group string="Encabezado / Límites de servicios">
                <group>
                  <field name="header_row_services"/>
                  <field name="max_service_rows"/>
                </group>
                <group>
                  <field name="empty_service_break"/>
                  <field name="strict_numeric_services"/>
                </group>
              </group>

              <group string="Columnas en Excel (tabla lateral de servicios)">
                <group>
                  <field name="col_srv_name" placeholder="J"
                         help="Columna donde está el nombre del servicio ('Flete', 'Seguro', etc.)"/>
                  <field name="col_srv_amount" placeholder="K"
                         help="Columna donde está el importe asociado a ese servicio"/>
                </group>
              </group>

              <group string="Productos servicio a usar">
                <group>
                  <field name="product_fob_id"/>
                  <field name="product_freight_id"/>
                </group>
                <group>
                  <field name="product_insurance_id"/>
                  <field name="product_other_id"/>
                </group>
              </group>

              <div class="o_form_label">
                Las filas de servicios se crearán como líneas de servicio
                en la Orden de Compra con cantidad = 1.
              </div>
            </page>

          </notebook>

          <!-- Resultado -->
          <group string="Resultado" invisible="note == False">
            <field name="note" nolabel="1" readonly="1"/>
          </group>

        </sheet>

        <footer>
          <button string="Importar" type="object" name="action_import" class="btn-primary"/>
          <button string="Cancelar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_po_line_import_wizard" model="ir.actions.act_window">
    <field name="name">Importar Oferta Comercial</field>
    <field name="res_model">po.line.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="view_id" ref="view_po_line_import_wizard_form"/>
    <field name="target">new</field>
    <field name="context">{'default_purchase_id': active_id}</field>
  </record>

  <record id="purchase_order_form_inherit_import_excel" model="ir.ui.view">
    <field name="name">purchase.order.form.inherit.import.excel</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <header position="inside">
        <button name="%(action_po_line_import_wizard)d"
                type="action"
                string="Importar Oferta"
                class="oe_highlight"
                invisible="state not in ('draft','sent')"/>
      </header>
    </field>
  </record>

</odoo>
