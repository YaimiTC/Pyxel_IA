<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_importation_cost_wizard_form" model="ir.ui.view">
        <field name="name">importation.cost.wizard.form</field>
        <field name="model">importation.cost.wizard</field>
        <field name="arch" type="xml">
            <form string="Agregar Costos Adicionales" class="o_form_padding">
                <group>
                    <field name="evaluation_id" invisible="1"/>
                    <field name="cost_line_ids">
                        <tree editable="bottom">
                            <field name="product_id" context="{'default_type': 'service'}"/>
                            <field name="name"/>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="distribution_type"/>
                            <field name="is_cost_special"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button string="Confirmar" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
