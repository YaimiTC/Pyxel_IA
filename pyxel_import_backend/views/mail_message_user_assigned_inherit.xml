<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="mail_message_user_assigned_inherit_process"
              inherit_id="mail.message_user_assigned">

        <xpath expr="//span[contains(., 'You have been assigned to the')]" position="replace">
            <span style="margin-top: 8px;">
                <t t-if="object._name == 'sale.order'">
                    Has sido asignado al
                    <t t-esc="model_description or 'documento'"/>
                    <t t-esc="object.display_name"/>.
                    <t t-if="object.process_id">
                        Secuencia:
                        <strong t-esc="object.process_id.name"/>
                    </t>
                </t>
                <t t-else="">
                    You have been assigned to the
                    <t t-esc="model_description or 'document'"/>
                    <t t-esc="object.display_name"/>.
                </t>
            </span>
        </xpath>

    </template>
</odoo>