<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_so_line_import_wizard_form" model="ir.ui.view">
    <field name="name">so.line.import.wizard.form</field>
    <field name="model">so.line.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importar Pedido de Venta">
        <sheet>

          <group>
            <field name="sale_id" required="1"
                   domain="[('state','in',('draft','sent'))]"/>
          </group>

          <group string="Archivo Excel">
            <field name="file_data" filename="file_name" required="1"/>
            <field name="file_name" readonly="1"/>
            <group>
              <field name="sheet_index"/>
            </group>
          </group>

          <notebook>

            <!-- TAB Productos -->
            <page string="Productos">
              <group string="Encabezado / Límites">
                <group>
                  <field name="header_row_products"/>
                  <field name="max_product_rows"/>
                </group>
                <group>
                  <field name="empty_product_break"/>
                  <field name="strict_numeric_products"/>
                </group>
              </group>

              <group string="Columnas Productos">
                <group>
                  <field name="col_prod_name" placeholder="B"/>
                  <field name="col_prod_code" placeholder="C"/>
                </group>
                <group>
                  <field name="col_prod_uom" placeholder="D"/>
                  <field name="col_prod_qty" placeholder="E"/>
                  <field name="col_prod_price" placeholder="F"/>
                </group>
              </group>

              <group string="Opciones de Creación">
                <group>
                  <field name="create_missing_products"/>
                  <field name="default_product_type"/>
                </group>
                <group>
                  <field name="default_uom_id"/>
                  <field name="clear_existing_lines"/>
                </group>
              </group>
            </page>

            <!-- TAB Servicios -->
            <page string="Servicios">
              <group string="Encabezado / Límites">
                <group>
                  <field name="header_row_services"/>
                  <field name="max_service_rows"/>
                </group>
                <group>
                  <field name="empty_service_break"/>
                  <field name="strict_numeric_services"/>
                </group>
              </group>

              <group string="Columnas Servicios">
                <group>
                  <field name="col_srv_name" placeholder="J" help="Las filas de servicios se crean como líneas tipo servicio con cantidad = 1."/>
                  <field name="col_srv_amount" placeholder="K"/>
                </group>
              </group>

            </page>

          </notebook>

          <group string="Resultado" invisible=" note == False ">
            <field name="note" nolabel="1" readonly="1"/>
          </group>

        </sheet>

        <footer>
          <button string="Importar" type="object" name="action_import" class="btn-primary"/>
          <button string="Cancelar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

    <!-- Acción -->
  <record id="action_so_line_import_wizard" model="ir.actions.act_window">
    <field name="name">Importar Oferta Comercial</field>
    <field name="res_model">so.line.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="context">{'default_sale_id': active_id}</field>
  </record>

  <!-- Botón en sale.order form -->
  <record id="view_order_form_inherit_import_lines" model="ir.ui.view">
    <field name="name">sale.order.form.import.lines</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
      <xpath expr="//header" position="inside">
        <button name="%(action_so_line_import_wizard)d"
                type="action"
                string="Importar Oferta"
                class="oe_highlight"
                invisible="state not in ('draft','sent')"/>
      </xpath>
    </field>
  </record>
</odoo>
