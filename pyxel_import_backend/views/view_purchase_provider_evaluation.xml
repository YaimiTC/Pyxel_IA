<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_provider_evaluation_tree" model="ir.ui.view">
        <field name="name">purchase.provider.evaluation.tree</field>
        <field name="model">purchase.provider.evaluation</field>
        <field name="arch" type="xml">
            <tree js_class="custom_provider_eval_tree" create="false">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="state"/>
                <field name="has_evaluations_to_apply"/>

            </tree>

        </field>
    </record>

    <record id="action_send_all_rfq_emails" model="ir.actions.server">
        <field name="name">Send RFQs</field>
        <field name="model_id" ref="model_purchase_provider_evaluation"/>
        <field name="state">code</field>
        <field name="code">record.action_send_all_rfq_emails()</field>
    </record>

    <record id="view_purchase_provider_evaluation_form" model="ir.ui.view">
            <field name="name">purchase.provider.evaluation.form</field>
            <field name="model">purchase.provider.evaluation</field>
            <field name="arch" type="xml">
                <form string="Supplier Evaluation">
                    <header>
                        <field name="purchase_order_count" invisible="1"/>
                        <field name ="has_evaluations_to_apply" invisible="1"/>
                        <button name="action_revaluate"
                                type="object"
                                string="Re-evaluate"
                                class="btn-secondary"
                                invisible =" state != 'draft' and  purchase_order_count  > 0" />
                        <button name="action_generate_eval_offer"
                                type="object"
                                string="Generate Offer"
                                class="btn-secondary" invisible="purchase_order_count == 0 or not cost_line_temp_ids or final_sale_order_id or (purchase_order_count > 0 and not has_evaluations_to_apply)"/>

                        <button name="action_send_all_rfq_emails"
                            type="object"
                            string="Send All RFQs"
                            class="btn-primary"
                            invisible="purchase_order_count == 0 "/>

                    </header>

                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="sale_order_id"/>
                            <field name="state"/>
                            <field name="final_sale_order_id" invisble="state != 'evaluating_offer'"/>
                        </group>
                        <notebook>
                            <page string="Lines">
                                <field name="evaluation_line_ids" readonly="1">
                                    <tree>
                                        <field name="product_id"/>
                                        <field name="product_uom_qty"/>
                                        <field name="product_uom"/>
                                        <field name="price_unit"/>
                                        <field name="suggested_supplier_id"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Purchase Orders">
                                <field name="purchase_order_ids" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="partner_id"/>
                                        <field name="amount_total"/>
                                        <field name="state"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Import costs" >
                                   <field name="cost_line_temp_ids"  readonly="final_sale_order_id">
                                        <tree editable="bottom">
                                            <field name="product_id" context="{'default_type': 'service'}"/>
                                            <field name="amount"/>
                                            <field name="distribution_type"/>
                                            <field name="purchase_ids"
                                               domain="[('id', 'in', parent.purchase_order_ids)]"
                                               widget="many2many_tags"/>
                                            <field name="is_cost_special"/>
                                        </tree>
                                    </field>
                            </page>
                        </notebook>
                    </sheet>
                     <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="message_ids" widget="mail_thread"/>
                        <field name="activity_ids" widget="mail_activity"/>
                    </div>
                </form>
            </field>
        </record>

   <record id="action_purchase_provider_evaluation_wizard" model="ir.actions.act_window">
        <field name="name">New Evaluation</field>
        <field name="res_model">wizard.evaluate.providers</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_sale_order_id': active_id}</field>
    </record>

   <record id="action_purchase_provider_evaluation" model="ir.actions.act_window">
        <field name="name">Supplier Evaluations</field>
        <field name="res_model">purchase.provider.evaluation</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="domain">[('sale_order_id', '=', active_id)]</field>
        <field name="context">{'default_sale_order_id': active_id}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
               There are no reviews yet.
            </p>

        </field>

    </record>






</odoo>