<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_importation_cargo_tree" model="ir.ui.view">
        <field name="name">importation.load.tree</field>
        <field name="model">importation.load</field>
        <field name="arch" type="xml">
            <tree string="Importation Loads">
                <field name="name"/>
                <field name="importation_id"/>
                <field name="cargo_type"/>
                <field name="state"/>
                <field name="arrival_date"/>
                <field name="extraction_date"/>
                <field name="return_date"/>
            </tree>
        </field>
    </record>

    <record id="view_importation_load_form" model="ir.ui.view">
        <field name="name">importation.load.form</field>
        <field name="model">importation.load</field>
        <field name="arch" type="xml">
            <form string="Importation Load">
                <header>
                     <button name="%(action_x_container_fill_wizard)d"
                        type="action"
                        string="Line Fill"
                        class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group  string="General information">
                            <field name="name"/>
                            <field name="importation_id"/>
                            <field name="purchase_condition" readonly="1"/>
                            <field name="cargo_type" invisible="purchase_condition not in ('FCL','LCL')"/>
                            <field name="size"/>
                            <field name="weight"/>
                            <field name="volume" invisible="purchase_condition == 'AWB'"/>
                            <field name="bulk" invisible="purchase_condition == 'LCL'"/>
                            <field name="supplier_invoice_number"/>
                        </group>

                        <group string="Container Status">
                            <field name="opening_date" invisible="purchase_condition not in ('FCL','LCL')"/>
                            <field name="arrival_date" invisible="purchase_condition not in ('FCL','LCL')"/>
                            <field name="release_date" invisible="purchase_condition not in ('FCL','LCL')"/>
                            <field name="extraction_date" invisible="purchase_condition not in ('FCL','LCL')"/>
                            <field name="return_date" invisible="purchase_condition == 'AWB'"/>
                            <field name="state" readonly="1"/>
                            <field name="currency_id" readonly="1"/>
                        </group>
                    </group>
                   <group>
                        <group string="Transport">

                            <field name="shipping_company" invisible="purchase_condition == 'FCL'"/>
                            <field name="airline" invisible="purchase_condition == 'AWB'"/>
                            <field name="transit_agency" invisible="purchase_condition not in ('FCL','LCL')"/>
                            <field name="pre_appointment_date"/>
                            <field name="appointment_date"/>
                            <field name="transport_company"/>
                            <field name="province"/>
                            <field name="truck_plate"/>
                            <field name="destination"/>
                            <field name="driver"/>
                        </group>

                        <group string="Transshipment">
                            <field name="is_transferred"/>
                            <field name="is_transshipment"/>
                            <field name="transshipment_type" invisible="is_transshipment == False"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Lines">
                            <field name="purchase_order_ids" />
                            <field name="cargo_line_ids" context="{'default_cargo_id': active_id}">
                                <tree editable="bottom">
                                    <field name="purchase_order_line_id" domain="[('order_id', 'in', parent.purchase_order_ids)]"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="quantity"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                    <field name="activity_ids" widget="mail_activity"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action and Menu -->
    <record id="action_importation_load" model="ir.actions.act_window">
        <field name="name">Importation Loads</field>
        <field name="res_model">importation.load</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_open_importation_wizard" model="ir.actions.server">
            <field name="name">Conciliacion</field>
            <field name="model_id" ref="model_importation_load"/>
            <field name="binding_model_id" ref="model_importation_load"/>
            <field name="state">code</field>
            <field name="code">
                action = {
                    'type': 'ir.actions.act_window',
                    'name': 'Conciliacion',
                    'res_model': 'average.container',
                    'view_mode': 'form',
                    'target': 'new',
                }
            </field>
    </record>



    <menuitem id="menu_importation_load" name="Loads" parent="menu_importation_process" sequence="2" action="action_importation_load"/>
</odoo>