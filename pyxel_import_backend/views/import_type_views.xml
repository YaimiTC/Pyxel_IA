<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_import_type_tree" model="ir.ui.view">
            <field name="model">import.type</field>
            <field name="arch" type="xml">
                <tree editable="bottom">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <!-- Acción y menú para Import Type -->
        <record id="action_import_type_config" model="ir.actions.act_window">
            <field name="name">Import Type</field>
            <field name="res_model">import.type</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="pyxel_import_backend.view_import_type_tree"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Start by creating an Import type.
                </p>
            </field>
        </record>

        <menuitem id="menu_import_type_config"
                  name="Import Type"
                  parent="menu_importation_config"
                  action="action_import_type_config"
                  sequence="20"/>
    </data>
</odoo>