<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_importation_process_kanban" model="ir.ui.view">
            <field name="name">importation.process.kanban</field>
            <field name="model">importation.process</field>
            <field name="arch" type="xml">
                <kanban default_group_by="stage_id" group_create="false">
                    <templates>
                         <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record">
                                 <!-- Resto de campos -->
                                <div class="o_kanban_details">
                                    <div><strong><field name="name"/></strong></div>
                                    <div><field name="provider_id"/></div>
                                    <div><field name="country_origin_id"/></div>
                                    <div><field name="purchase_condition_number"/></div>

                                </div>
                                 <!-- Avatar del usuario que creó el registro -->
                                 <div class="o_kanban_avatar">
                                    <field name="create_uid" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

            <record id="view_importation_process_tree" model="ir.ui.view">
                <field name="name">importation.process.tree</field>
                <field name="model">importation.process</field>
                <field name="arch" type="xml">
                    <tree>
                        <field name="name"/>
                        <field name="provider_id"/>
                        <field name="purchase_condition"/>
                        <field name="purchase_condition_number"/>
                        <field name="state"/>
                        <field name="estimated_start_date"/>
                        <field name="estimated_end_date"/>
                    </tree>
                </field>
            </record>

             <record id="view_importation_process_form" model="ir.ui.view">
                    <field name="name">importation.process.form</field>
                    <field name="model">importation.process</field>
                    <field name="arch" type="xml">
                        <form>

                            <header>
                                <field name="final_sale_order_id" invisible="1"/>
                                <button name="action_create_cost_sale_order"
                                        type="object"
                                        string="Generar Venta de Costos"
                                        class="btn-primary"
                                        invisible="cost_line_ids == False or final_sale_order_id"/>

                                <button name="action_start_progress" string="Start Import" type="object" class="btn-primary" invisible="state != 'evaluating'"/>
                                <button name="action_finish_progress" string="Finish" type="object" class="btn-success" invisible="state != 'in_progress'"/>
<!--                                <field name="state" widget="statusbar" statusbar_visible="draft,evaluating,in_progress,done"/>-->
                                <field name="stage_id" widget="statusbar" options="{'clickable': True}" domain="[]"/>
                            </header>

                            <sheet>
                                <div class="oe_button_box" name="button_box">
                                    <!-- Aquí insertas tu botón -->

                                    <button name="action_view_sale_orders"
                                            type="object"
                                            class="oe_stat_button"
                                            icon="fa-shopping-cart" >
                                        <field name="sale_order_count" widget="statinfo" string="Órdenes de Venta"/>
                                    </button>
                                </div>
                                <group>
                                    <group>
                                        <field name="name" readonly="1"/>
                                        <field name="provider_id"/>
                                        <field name="purchase_condition"/>
                                        <field name="purchase_condition_number"/>
                                        <field name="declaration"/>
                                        <field name="country_origin_id"/>
                                        <field name="is_third_party_contract"/>
                                         <field name="state"/>
                                    </group>
                                    <group>
                                        <field name="estimated_start_date"/>
                                        <field name="estimated_end_date"/>
                                        <field name="departure_date"/>
                                        <field name="declaration_date"/>
                                        <field name="documentation_sent_date"/>
                                    </group>
                                </group>

                                <notebook>
                                    <page string="Documents">
                                        <group>
                                            <field name="origin_certificate" filename="origin_certificate_filename"/>
                                            <field name="export_certificate" filename="export_certificate_filename"/>
                                            <field name="quality_certificate" filename="quality_certificate_filename"/>
                                            <field name="commercial_invoice" filename="commercial_invoice_filename"/>
                                            <field name="signed_offer" filename="signed_offer_filename"/>
                                            <field name="documentation_file" filename="documentation_file_filename"/>
                                            <field name="packing_list" filename="packing_list_filename"/>
                                        </group>
                                    </page>

                                    <page string="Load">
                                        <field name="load_tracking_ids">
                                            <tree>
                                                <field name="name"/>
                                                <field name="cargo_type"/>
                                                <field name="size"/>
                                                <field name="weight"/>
                                                <field name="volume"/>
                                                <field name="arrival_date"/>
                                                <field name="release_date"/>
                                                <field name="return_date"/>
                                                <field name="extraction_date"/>
                                                <field name="state"/>
                                            </tree>
                                            <form>
                                                <sheet>
                                                  <group>
                                                    <field name="name"/>
                                                    <field name="importation_id"/>
                                                    <field name="purchase_condition" readonly="1"/>
                                                    <field name="cargo_type"/>
                                                    <field name="size"/>
                                                    <field name="weight"/>
                                                    <field name="volume"/>
                                                    <field name="supplier_invoice_number"/>
                                                  </group>

                                                  <group string="Container Status">
                                                    <field name="arrival_date"/>
                                                    <field name="release_date"/>
                                                    <field name="extraction_date"/>
                                                    <field name="return_date"/>
                                                    <field name="state" readonly="1"/>
                                                  </group>

                                                  <group string="Transport">
                                                    <field name="airline"/>
                                                    <field name="transit_agency"/>
                                                    <field name="pre_appointment_date"/>
                                                    <field name="appointment_date"/>
                                                    <field name="transport_company"/>
                                                    <field name="province"/>
                                                    <field name="truck_plate"/>
                                                    <field name="destination"/>
                                                    <field name="driver"/>
                                                  </group>

                                                  <group string="Transfer">
                                                    <field name="is_transferred"/>
                                                    <field name="is_transshipment"/>
                                                    <field name="transshipment_type" invisible="is_transshipment == False"/>
                                                  </group>

                                                  <notebook>
                                                    <page string="Product Lines">
                                                      <field name="cargo_line_ids">
                                                        <tree editable="bottom">
                                                          <field name="purchase_order_line_id"/>
                                                          <field name="product_id" readonly="1"/>
                                                          <field name="quantity"/>
                                                        </tree>
                                                      </field>
                                                    </page>
                                                  </notebook>

                                                </sheet>
                                              </form>
                                        </field>
                                    </page>

                                    <page string="Purchase Orders">
                                        <field name="purchase_order_ids">
                                            <tree>
                                                <field name="name"/>
                                                <field name="partner_id"/>
                                                <field name="amount_total"/>
                                                <field name="state"/>
                                            </tree>
                                        </field>
                                    </page>
                                    <page string="Import costs">
                                       <field name="cost_line_ids">
                                            <tree editable="bottom">
                                                <field name="product_id" context="{'default_type': 'service'}"/>
                                                <field name="amount"/>
                                                <field name="distribution_type"/>
                                                <field name="purchase_ids"
                                                   domain="[('id', 'in', parent.purchase_order_ids)]"
                                                   widget="many2many_tags"/>
                                                <field name="is_cost_special"/>
                                            </tree>
                                        </field>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </record>

                <record id="action_importation_process" model="ir.actions.act_window">
                    <field name="name">Imports</field>
                    <field name="res_model">importation.process</field>
                    <field name="view_mode">kanban,tree,form</field>
                    <field name="context">{'group_by': 'stage_id'}</field>
                    <field name="help" type="html">
                        <p>Manage import processes from this view.</p>
                    </field>
                </record>


             <menuitem id="menu_importation_root" name="Imports" sequence="10"/>
             <menuitem id="menu_importation_process" name="Imports" parent="menu_importation_root" >
                 <menuitem id="menu_importation_solicitud" sequence="1" name="Imports" action="action_importation_process"/>
             </menuitem>



</odoo>