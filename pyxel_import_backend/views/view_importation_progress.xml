<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_importation_process_kanban" model="ir.ui.view">
        <field name="name">importation.process.kanban</field>
        <field name="model">importation.process</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" group_create="false" group_order="sequence">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <!-- Resto de campos -->
                            <div class="o_kanban_details">
                                <div>
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div>
                                    <field name="provider_id"/>
                                </div>
                                <div>
                                    <field name="country_origin_id"/>
                                </div>
                                <div>
                                    <field name="purchase_condition_number"/>
                                </div>
                                <div>
                                    <strong>Days in the stage:</strong>
                                    <field name="days_in_stage"/>
                                </div>
                            </div>
                            <!-- Avatar del usuario que creó el registro -->
                            <div class="o_kanban_avatar">
                                <field name="create_uid" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_importation_process_tree" model="ir.ui.view">
        <field name="name">importation.process.tree</field>
        <field name="model">importation.process</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_uid"/>
                <field name="name"/>
                <field name="provider_id"/>
                <field name="customer_id"/>
                <field name="import_type_id"/>
                <field name="purchase_condition_number"/>
                <field name="declaration"/>
                <field name="is_third_party_contract"/>
                <field name="purchase_order_count"/>
                <field name="sale_order_count"/>
                <field name="invoice_count"/>
                <field name="load_tracking_count"/>
                <field name="stage_id"/>
                <field name="country_origin_id"/>
                <field name="estimated_start_date"/>
                <field name="estimated_end_date"/>
            </tree>
        </field>
    </record>

    <record id="view_importation_process_form" model="ir.ui.view">
        <field name="name">importation.process.form</field>
        <field name="model">importation.process</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="final_sale_order_id" invisible="1"/>
                    <button name="action_create_cost_sale_order"
                            type="object"
                            string="Generar Venta de Costos"
                            class="btn-primary"
                            invisible="not cost_line_ids or final_sale_order_id"/>

                    <button name="action_start_progress" string="Start Import" type="object" class="btn-primary"
                            invisible="state != 'evaluating'"/>
                    <!--                                <button name="action_finish_progress" string="Finish" type="object" class="btn-success" invisible="state != 'in_progress'"/>-->
                    <!--                                <field name="state" widget="statusbar" statusbar_visible="draft,evaluating,in_progress,done"/>-->
                    <field name="stage_id" widget="statusbar" options="{'clickable': True}" domain="[]" context="{}"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_orders"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart">
                            <field name="sale_order_count" widget="statinfo" string="Sale Orders"/>
                        </button>
                        <button name="action_view_related_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-invoice-dollar">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                        <button name="action_view_purchase_orders"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart">
                            <field name="purchase_order_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                        <button name="action_view_load_tracking"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart">
                            <field name="load_tracking_count" widget="statinfo" string="Importation Load"/>
                        </button>

                    </div>
                    <group name="main_group">
                        <group name="info_group">
                            <field name="process_id" options="{'no_create': True, 'no_open': True}" readonly="True"
                                   context="{'default_importation_id': id}"/>
                            <field name="name" readonly="1"/>
                            <field name="provider_id" />
                            <field name="customer_id" />
                            <field name="country_origin_id"/>
                            <field name="filtered_incoterm" invisible="True"/>
                            <field name="filtered_import_type" invisible="True"/>
                            <field name="incoterm_import_type_id" invisible="True"/>
                            <field name="incoterm_id" domain="filtered_incoterm" readonly="True"/>
                            <field name="import_type_id" domain="filtered_import_type"/>
                            <field name="use_port" invisible="True"/>
                            <field name="use_airport" invisible="True"/>
                            <field name="filtered_port" invisible="True"/>
                            <field name="filtered_airport" invisible="True"/>
                            <field name="port" invisible="use_port == False" domain="filtered_port"/>
                            <field name="airport" invisible="use_airport == False" domain="filtered_airport"/>
                            <field name="purchase_condition_number"/>
                            <field name="declaration"/>
                            <field name="state" readonly="1"/>
                        </group>

                        <group name="date_group">
                            <field name="estimated_start_date"/>
                            <field name="estimated_end_date"/>
                            <field name="departure_date"/>
                            <field name="declaration_date"/>
                            <field name="documentation_sent_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Documents" name="documents">
                            <field name="has_origin_certificate" invisible="True"/>
                            <field name="has_export_certificate" invisible="True"/>
                            <field name="has_quality_certificate" invisible="True"/>
                            <field name="has_packing_list" invisible="True"/>
                            <field name="has_awb" invisible="True"/>
                            <field name="has_bl" invisible="True"/>
                            <group>
                                <field name="origin_certificate" filename="origin_certificate_filename"
                                       invisible="has_origin_certificate == False"/>
                                <field name="export_certificate" filename="export_certificate_filename"
                                       invisible="has_export_certificate == False"/>
                                <field name="quality_certificate" filename="quality_certificate_filename"
                                       invisible="has_quality_certificate == False"/>
                                <field name="documentation_file" filename="documentation_file_filename"
                                       invisible="has_awb == False and has_bl == False"/>
                                <field name="packing_list" filename="packing_list_filename"
                                       invisible="has_packing_list == False"/>
                            </group>
                        </page>

                        <page string="Importation Load" name="importation_load">
                            <field name="load_tracking_ids" context="{'default_importation_id': active_id}">
                                <tree>
                                    <field name="name"/>
                                    <field name="cargo_type" optional="show"/>
                                    <field name="size"/>
                                    <field name="weight" optional="show"/>
                                    <field name="volume" optional="show"/>
                                    <field name="arrival_date" optional="show"/>
                                    <field name="release_date" optional="show"/>
                                    <field name="return_date" optional="show"/>
                                    <field name="extraction_date" optional="show"/>
                                    <field name="days_in_tcm"/>
                                    <field name="days_extracted"/>
                                    <field name="state"/>
                                </tree>
                                <form>
                                    <header>
                                        <button name="%(action_x_container_fill_wizard)d"
                                                type="action"
                                                string="Line Fill"
                                                class="btn-secondary"/>
                                    </header>
                                    <sheet>
                                        <group>
                                            <group string="General information">
                                                <field name="hide_cargo_type" invisible="1"/>
                                                <field name="hide_volume" invisible="1"/>
                                                <field name="hide_bulk" invisible="1"/>

                                                <field name="name"/>
                                                <field name="importation_id"/>
                                                <field name="cargo_type" invisible="hide_cargo_type"/>
                                                <field name="size"/>
                                                <field name="weight"/>
                                                <field name="volume" invisible="hide_volume == True"/>
                                                <field name="bulk" invisible="hide_bulk == True"/>
                                                <field name="supplier_invoice_number"/>
                                            </group>

                                            <group string="Container Status">
                                                <field name="hide_opening_date" invisible="1"/>
                                                <field name="hide_arrival_date" invisible="1"/>
                                                <field name="hide_release_date" invisible="1"/>
                                                <field name="hide_extraction_date" invisible="1"/>
                                                <field name="hide_return_date" invisible="1"/>

                                                <field name="opening_date" invisible="hide_opening_date"/>
                                                <field name="arrival_date" invisible="hide_arrival_date"/>
                                                <field name="release_date" invisible="hide_release_date"/>
                                                <field name="extraction_date" invisible="hide_extraction_date"/>
                                                <field name="return_date" invisible="hide_return_date"/>
                                                <field name="state" readonly="1"/>
                                                <field name="currency_id" readonly="1"/>
                                                <field name="days_in_tcm" readonly="1"/>
                                                <field name="days_extracted" readonly="1"/>
                                            </group>
                                        </group>
                                        <group>
                                            <group string="Transport">
                                                <field name="hide_shipping_company" invisible="1"/>
                                                <field name="hide_airline" invisible="1"/>
                                                <field name="hide_transit_agency" invisible="1"/>

                                                <field name="shipping_company" invisible="hide_shipping_company"/>
                                                <field name="airline" invisible="hide_airline"/>
                                                <field name="transit_agency" invisible="hide_transit_agency"/>
                                                <field name="pre_appointment_date"/>
                                                <field name="appointment_date"/>
                                                <field name="transport_company"/>
                                                <field name="province"/>
                                                <field name="truck_plate"/>
                                                <field name="destination"/>
                                                <field name="driver"/>
                                            </group>

                                            <group string="Transshipment">
                                                <field name="is_transferred"/>
                                                <field name="is_transshipment"/>
                                                <field name="transshipment_type" invisible="is_transshipment == False"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Product Lines">
                                                <field name="purchase_order_ids"/>
                                                <field name="cargo_line_ids" context="{'default_cargo_id': active_id}">
                                                    <tree editable="bottom">
                                                        <field name="purchase_order_line_id"
                                                               domain="[('order_id', 'in', parent.purchase_order_ids)]"/>
                                                        <field name="product_id" readonly="1"/>
                                                        <field name="quantity"/>
                                                    </tree>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Purchase Orders" name="purchase_orders">
                            <field name="purchase_order_ids"
                                   domain="['|', ('importation_id', '=', False), ('importation_id', '=', active_id)]">
                                <tree>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="amount_total"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Import costs" name="import_costs">
                            <field name="cost_line_ids">
                                <tree editable="top" create="true" edit="true">
                                    <field name="product_id"
                                           context="{'default_detailed_type': 'service', 'default_taxes_id': [], 'default_supplier_taxes_id': []}"/>
                                    <field name="amount"/>
                                    <field name="distribution_type"/>
                                    <field name="purchase_ids"
                                           domain="[('id', 'in', parent.purchase_order_ids)]"
                                           widget="many2many_tags"/>
                                    <field name="is_cost_special"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                    <field name="activity_ids" widget="mail_activity"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_importation_process" model="ir.actions.act_window">
        <field name="name">Imports</field>
        <field name="res_model">importation.process</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'group_by': 'stage_id'}</field>
        <field name="help" type="html">
            <p>Manage import processes from this view.</p>
        </field>
    </record>


    <menuitem id="menu_importation_root" name="Imports" sequence="10"
              web_icon="pyxel_import_backend,static/src/imgs/menu_icon.png"/>
    <menuitem id="menu_importation_process" name="Imports" parent="menu_importation_root">
        <menuitem id="menu_importation_solicitud" sequence="1" name="Imports" action="action_importation_process"/>
    </menuitem>


</odoo>