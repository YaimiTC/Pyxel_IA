<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_tree_inherit_contact_type" model="ir.ui.view">
        <field name="name">res.partner.tree.inherit.contact.type</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='phone']" position="after">
                <field name="contact_type_id" optional="show" />
                <field name="license_holder" optional="show" />
                <field name="count_imports" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_import" model="ir.ui.view">
        <field name="name">res.partner.import.view</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('o_address_format')]" position="after">
                <field name="dap" invisible="contact_type_id not in (1, 3)"/>
            </xpath>

            <notebook position="inside">
                <page string="Importation">
                    <group name="container_row_2">
                        <group string="Legal Information">
                            <!-- Si es Cliente o Proveedor -->
                            <field name="management_type_id" invisible="contact_type_id not in (1, 3)" />
                            <!-- Si es Mipyme,CNA,PDL -->
                            <label for="deed_number" string="Notarial Deed" style="font-weight:bold;" invisible="management_type_id not in (1, 6, 7)" />
                            <!-- <label for="deed_number" string="Notarial Deed" style="font-weight:bold;" invisible="management_type_id not in ('out_invoice', 'out_refund', 'out_receipt')"/> -->
                            <!-- <label for="deed_number" string="Escritura notarial" style="font-weight:bold;" invisible="management_type_id not in ('out_invoice', 'out_refund', 'out_receipt')"/> -->
                            <!-- Si es TCP  -->
                            <label for="deed_number" string="Project Registration Number" style="font-weight:bold;" invisible="management_type_id != 2"/>
                            <!-- <label for="deed_number" string="Número de registro de proyecto" style="font-weight:bold;" invisible="management_type_id not in ('out_invoice', 'out_refund', 'out_receipt')"/> -->
                            <!-- Si es Estatal -->
                            <label for="deed_number" string="Public Deed" style="font-weight:bold;" invisible="management_type_id != 5"/>
                            <!-- <label for="deed_number" string="Escritura pública" style="font-weight:bold;" invisible="management_type_id not in ('out_invoice', 'out_refund', 'out_receipt')"/> -->
                            <!-- Si es Persona Natural, Sucursal Extranjera -->
                            <div class="d-flex" invisible="management_type_id in (3, 4, False)">
                                <field name="deed_number" nolabel="1" />
                                <field name="deed_date" nolabel="1" class="ps-4" />
                                <!-- <field name="deed_date"  nolabel="1" placeholder="Date"/> -->
                            </div>
                            <field name="legal_document" filename="legal_document_filename" />
                            <field name="license_holder" invisible="contact_type_id in (1, 3)"/>
                        </group>
                        <group string="Initial Hiring">
                            <field name="contact_type_id"/>
                            <field name="activity_number"/>
                            <field name="hiring_number"/>
                        </group>
                    </group>
                    <group string="Activities">
                        <field name="legal_activity_ids">
                            <tree editable="bottom">
                                <field name="name" />
                                <field name="license_number" />
                            </tree>
                        </field>
                    </group>
                    <group string="Contracts">
                        <field name="contract_import_ids" create="1" edit="1">
                            <tree editable="bottom">
                                <field name="contract_number" />
                                <field name="activity_number" />
                                <field name="hiring_number" />
                                <field name="start_date" />
                                <field name="end_date" />
                                <field name="active_contract" readonly="1" />
                                <field name="parent_contract_id" />
                                <field name="contract_file" filename="contract_file_filename" />
                            </tree>
                            <form>
                                <group>
                                    <field name="contract_number" />
                                    <field name="activity_number" />
                                    <field name="hiring_number" />
                                    <field name="start_date" />
                                    <field name="end_date" />
                                    <field name="active_contract" readonly="1" />
                                    <field name="parent_contract_id" />
                                    <field name="contract_file" filename="contract_file_filename" />
                                </group>
                            </form>
                        </field>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <record id="view_res_partner_contract_form" model="ir.ui.view">
        <field name="name">res.partner.contract.form</field>
        <field name="model">res.partner.contract.import</field>
        <field name="arch" type="xml">
            <form string="Contract">
                <sheet>
                    <h1>
                        <field name="partner_id" />
                    </h1>
                    <group name="container_row_2">
                        <group>
                            <field name="parent_contract_id" />
                            <field name="contract_number" />
                            <field name="start_date" />
                            <field name="end_date" />
                        </group>
                        <group>
                            <field name="activity_number" />
                            <field name="hiring_number" />
                            <field name="active_contract" readonly="1" />
                            <field name="contract_file" filename="contract_file_filename" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_res_partner_contract_import_tree" model="ir.ui.view">
        <field name="name">res.partner.contract.import.tree</field>
        <field name="model">res.partner.contract.import</field>
        <field name="arch" type="xml">
            <tree>
                <field name="contract_number" />
                <field name="activity_number" />
                <field name="hiring_number" />
                <field name="start_date" />
                <field name="end_date" />
                <field name="active_contract" />
            </tree>
        </field>
    </record>

    <record id="action_res_partner_contract_import" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">res.partner.contract.import</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No contracts yet.
            </p>
        </field>
    </record>

    <record id="action_res_partner_contact_type" model="ir.actions.act_window">
        <field name="name">Contact Types</field>
        <field name="res_model">res.partner.contact.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create and manage custom types to categorize contacts based on your business.
            </p>
        </field>
    </record>

    <record id="action_res_partner_management_type" model="ir.actions.act_window">
        <field name="name">Management Types</field>
        <field name="res_model">res.partner.management.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create and manage different types of business management associated with clients/suppliers.
                <!-- Crea y gestiona los diferentes tipos de gestión empresarial asociados a los clientes/proveedores. -->
            </p>
        </field>
    </record>

    <!-- Submenu to access contracts -->
    <menuitem id="menu_contracts_import" name="Contracts"
              parent="contacts.menu_contacts"
              action="action_res_partner_contract_import"
              sequence="20"/>

    <menuitem id="menu_partner_contact_type"
          name="Contact Types"
          parent="contacts.menu_contacts"
          action="action_res_partner_contact_type"
          sequence="20"/>

    <menuitem id="menu_partner_management_type"
          name="Management Types"
          parent="contacts.menu_contacts"
          action="action_res_partner_management_type"
          sequence="21"/>
</odoo>