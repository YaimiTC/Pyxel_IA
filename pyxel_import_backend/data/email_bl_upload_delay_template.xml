<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="email_template_bl_upload_delay" model="mail.template">
            <field name="name">Alerta: Subida Tardía de BL</field>
            <field name="model_id" ref="pyxel_import_backend.model_importation_process"/>

            <field name="subject">Alerta: Archivo subido fuera de tiempo para {{ object.name or '' }}</field>
            <field name="email_from">{{ object.create_uid.company_id.email_formatted or object.create_uid.company_id.email or '' }}</field> <field name="email_to">{{ object.create_uid.email or '' }}</field>

            <field name="email_to">{{ object.create_uid.email or '' }}</field>
            <field name="lang">{{ object.create_uid.lang or '' }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hola <t t-out="object.create_uid.name or ''"/>,</p>
                    <p>Se detectó que el archivo de Lista de Empaque de la importación <strong><t t-out="object.name or ''"/></strong> fue subido más de 72 horas después de la fecha de documentación <t t-out="object.documentation_sent_date or ''"/>.</p>
                    <p>Por favor verifica la carga de documentación.</p>
                </div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>