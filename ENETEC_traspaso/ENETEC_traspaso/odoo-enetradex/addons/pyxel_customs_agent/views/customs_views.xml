<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== Lista de Trámites de aduana ===== -->
    <record id="view_customs_process_tree" model="ir.ui.view">
        <field name="name">importation.process.customs.tree</field>
        <field name="model">importation.process</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0"
                  decoration-muted="en_customs_agent_id and not en_customs_dm_done"
                  decoration-success="en_customs_dm_done">
                <field name="name" string="Referencia"/>
                <field name="provider_id" string="Proveedor"/>
                <field name="customer_id" string="Cliente"/>
                <field name="en_customs_agent_id" string="Apoderado asignado"
                       widget="many2one_avatar_user"/>
                <field name="en_customs_dm_done" string="DM lista" widget="boolean_toggle" readonly="1"/>
                <field name="en_ready_for_customs" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ===== Búsqueda ===== -->
    <record id="view_customs_process_search" model="ir.ui.view">
        <field name="name">importation.process.customs.search</field>
        <field name="model">importation.process</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Referencia"/>
                <field name="provider_id"/>
                <field name="customer_id"/>
                <field name="en_customs_agent_id"/>
                <filter name="pendientes" string="DM pendientes"
                        domain="[('en_customs_dm_done', '=', False)]"/>
                <filter name="completadas" string="Mostrar DM completadas"
                        domain="[('en_customs_dm_done', '=', True)]"/>
                <separator/>
                <filter name="mias" string="Asignadas a mí"
                        domain="[('en_customs_agent_id', '=', uid)]"/>
                <filter name="sin_apoderado" string="Sin apoderado"
                        domain="[('en_customs_agent_id', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- ===== Formulario del apoderado ===== -->
    <record id="view_customs_process_form" model="ir.ui.view">
        <field name="name">importation.process.customs.form</field>
        <field name="model">importation.process</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Trámite de aduana" create="0" delete="0">
                <header>
                    <field name="stage_id" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="provider_id" readonly="1"/>
                            <field name="customer_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="en_customs_agent_id" widget="many2one_avatar_user"
                                   options="{'no_create': True}"/>
                            <field name="en_ready_for_customs" widget="boolean_toggle" readonly="1"/>
                            <field name="en_customs_dm_done" widget="boolean_toggle" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- 1) Documentos de entrada (solo lectura) -->
                        <page string="Documentos de entrada">
                            <separator string="Documentos de la importación (BL/AWB, certificados)"/>
                            <field name="en_import_document_ids" nolabel="1" readonly="1">
                                <tree create="0" delete="0" edit="0">
                                    <field name="document_label" string="Documento"/>
                                    <field name="ai_state" string="Dictamen IA" widget="badge"
                                           decoration-success="ai_state == 'passed'"
                                           decoration-warning="ai_state == 'doubt'"
                                           decoration-danger="ai_state == 'rejected'"
                                           decoration-info="ai_state == 'validating'"/>
                                    <field name="portal_state" string="Estado" widget="badge"
                                           decoration-success="portal_state == 'approved'"
                                           decoration-warning="portal_state in ('in_review','validating')"
                                           decoration-danger="portal_state == 'rejected'"/>
                                    <field name="attachment_id" column_invisible="1"/>
                                    <button name="action_view_document" type="object" string="Ver"
                                            class="btn-link" invisible="not attachment_id"/>
                                </tree>
                            </field>
                            <separator string="Documentos por Orden de Compra"/>
                            <field name="en_import_oc_doc_ids" nolabel="1" readonly="1">
                                <tree create="0" delete="0" edit="0" default_order="purchase_order_id, sequence">
                                    <field name="purchase_order_id" string="OC"/>
                                    <field name="document_label" string="Documento"/>
                                    <field name="ai_state" string="Dictamen IA" widget="badge"
                                           decoration-success="ai_state == 'passed'"
                                           decoration-warning="ai_state == 'doubt'"
                                           decoration-danger="ai_state == 'rejected'"
                                           decoration-info="ai_state == 'validating'"/>
                                    <field name="portal_state" string="Estado" widget="badge"
                                           decoration-success="portal_state == 'approved'"
                                           decoration-warning="portal_state in ('in_review','validating')"
                                           decoration-danger="portal_state == 'rejected'"/>
                                    <field name="attachment_id" column_invisible="1"/>
                                    <button name="action_view_document" type="object" string="Ver"
                                            class="btn-link" invisible="not attachment_id"/>
                                </tree>
                            </field>
                        </page>

                        <!-- 2) Declaración de Mercancía (DM) -->
                        <page string="Declaración de Mercancía (DM)">
                            <div class="alert alert-warning" role="alert"
                                 invisible="en_ready_for_customs">
                                <i class="fa fa-exclamation-triangle me-1"/>
                                Los documentos de entrada aún no están aprobados. No es posible
                                gestionar la DM hasta que el expediente esté completo.
                            </div>
                            <field name="en_import_dm_doc_ids" nolabel="1"
                                   invisible="not en_ready_for_customs">
                                <tree editable="bottom" create="0" delete="0"
                                      default_order="purchase_order_id"
                                      decoration-success="dm_confirmed">
                                    <field name="purchase_order_id" string="OC" readonly="1"/>
                                    <field name="document_filename" string="PDF DM" readonly="1"/>
                                    <field name="ai_state" string="IA" readonly="1" widget="badge"
                                           decoration-success="ai_state == 'passed'"
                                           decoration-warning="ai_state == 'doubt'"
                                           decoration-danger="ai_state == 'rejected'"
                                           decoration-info="ai_state == 'validating'"/>
                                    <field name="dm_extraction_state" string="Extracción" readonly="1" widget="badge"
                                           decoration-success="dm_extraction_state == 'extracted'"
                                           decoration-info="dm_extraction_state == 'manual'"/>
                                    <field name="dm_number" string="Nº DM"/>
                                    <field name="dm_cif_value" string="CIF (USD)" widget="float" digits="[16,2]"/>
                                    <field name="dm_arancel_total" string="Aranceles (MN)" widget="float" digits="[16,2]"/>
                                    <field name="dm_servicio_aduana" string="Servicio Aduana (MN)" widget="float" digits="[16,2]"/>
                                    <field name="dm_arancel_notes" string="Notas arancelarias" optional="hide"/>
                                    <field name="dm_confirmed" string="Confirmado" readonly="1"/>
                                    <field name="attachment_id" column_invisible="1"/>
                                    <button name="action_open_review" type="object" string="Subir DM"
                                            class="btn-link" invisible="attachment_id"/>
                                    <button name="action_view_document" type="object" string="Ver DM"
                                            class="btn-link" invisible="not attachment_id"/>
                                    <button name="action_dm_replace" type="object" string="Reemplazar"
                                            class="btn-link" invisible="not attachment_id"/>
                                    <button name="action_dm_confirm" type="object" string="Confirmar"
                                            class="btn-success btn-sm"
                                            invisible="not attachment_id or dm_confirmed"/>
                                    <button name="action_dm_reopen" type="object" string="Reabrir"
                                            class="btn-link" groups="base.group_system"
                                            invisible="not dm_confirmed"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
