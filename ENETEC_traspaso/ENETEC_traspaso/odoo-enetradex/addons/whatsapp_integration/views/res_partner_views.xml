<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_whatsapp" model="ir.ui.view">
        <field name="name">res.partner.form.whatsapp</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object" name="action_whatsapp_logs"
                        icon="fa-whatsapp">
                    <field name="whatsapp_message_count" widget="statinfo" string="WhatsApp"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="WhatsApp" name="whatsapp">
                    <group>
                        <group>
                            <field name="whatsapp_number" placeholder="+5352807765"/>
                            <field name="whatsapp_opt_in"/>
                        </group>
                        <group>
                            <field name="whatsapp_formatted"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
