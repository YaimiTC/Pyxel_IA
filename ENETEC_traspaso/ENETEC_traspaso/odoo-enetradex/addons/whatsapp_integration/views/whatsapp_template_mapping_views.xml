<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wa_mapping_tree" model="ir.ui.view">
        <field name="name">whatsapp.template.mapping.tree</field>
        <field name="model">whatsapp.template.mapping</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="event"/>
                <field name="model_id"/>
                <field name="template_name"/>
                <field name="lang_code"/>
                <field name="category"/>
                <field name="is_default"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_wa_mapping_form" model="ir.ui.view">
        <field name="name">whatsapp.template.mapping.form</field>
        <field name="model">whatsapp.template.mapping</field>
        <field name="arch" type="xml">
            <form string="Mapeo de plantilla">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="event"/>
                            <field name="model_id"/>
                            <field name="is_default"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="template_name"/>
                            <field name="lang_code"/>
                            <field name="category"/>
                        </group>
                    </group>
                    <separator string="Variables del cuerpo ({{1}}, {{2}}...)"/>
                    <field name="variable_ids">
                        <tree editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="field_path"/>
                            <field name="fallback"/>
                        </tree>
                    </field>
                    <field name="note" placeholder="Notas internas"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wa_mapping" model="ir.actions.act_window">
        <field name="name">Plantillas WhatsApp</field>
        <field name="res_model">whatsapp.template.mapping</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
