<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ENETRADEX Fase 0: bandeja única del abogado con chip y agrupar/filtrar
         por Tipo de empresa (Cliente / Proveedor). -->

    <!-- Búsqueda de oportunidades: filtros + group by -->
    <record id="view_crm_case_opportunities_filter_enetec" model="ir.ui.view">
        <field name="name">crm.lead.search.enetec.party</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="en_filter_client" string="Clientes"
                        domain="[('en_party_role', '=', 'client')]"/>
                <filter name="en_filter_supplier" string="Proveedores"
                        domain="[('en_party_role', '=', 'supplier')]"/>
                <separator/>
                <filter name="en_group_party" string="Tipo de empresa"
                        context="{'group_by': 'en_party_role'}"/>
            </xpath>
        </field>
    </record>

    <!-- Tarjeta del kanban de CRM (Pipeline): badges de acreditación en vez de
         la tarjeta de ventas genérica. -->
    <record id="crm_kanban_enetec_accred" model="ir.ui.view">
        <field name="name">crm.lead.kanban.enetec.accred</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//templates" position="before">
                <field name="en_party_role"/>
                <field name="en_accred_state"/>
                <field name="en_partner_vat"/>
                <field name="en_origin_label"/>
                <field name="en_doc_count"/>
                <field name="en_also_registered"/>
            </xpath>
            <xpath expr="//strong[hasclass('o_kanban_record_title')]" position="after">
                <div t-attf-class="en_acc_kard #{record.en_party_role.raw_value == 'supplier' ? 'is-sup' : 'is-cli'}">
                    <div class="en_acc_head">
                        <span class="en_acc_chip">
                            <i t-attf-class="fa #{record.en_party_role.raw_value == 'supplier' ? 'fa-ship' : 'fa-building-o'}" title="Tipo"/>
                            <t t-esc="record.en_party_role.raw_value == 'supplier' ? 'Proveedor' : 'Cliente'"/>
                        </span>
                        <span t-attf-class="en_acc_state #{record.en_accred_state.raw_value == 'accredited' ? 'ok' : 'wait'}"
                              t-esc="record.en_accred_state.raw_value == 'accredited' ? 'Acreditado' : 'Pendiente'"/>
                    </div>
                    <div class="en_acc_meta"><i class="fa fa-user-circle-o" title="Origen"/> <t t-esc="record.en_origin_label.value"/></div>
                    <div class="en_acc_meta"><i class="fa fa-paperclip" title="Documentos"/>
                        <t t-if="record.en_doc_count.raw_value"><t t-esc="record.en_doc_count.raw_value"/> documento(s) subido(s)</t>
                        <t t-else="">Sin documentos aún</t>
                    </div>
                    <div t-if="record.en_also_registered.value" class="en_acc_link">
                        <i class="fa fa-sitemap" title="Vínculo"/> También registró a: <t t-esc="record.en_also_registered.value"/>
                    </div>
                    <div t-if="record.en_partner_vat.raw_value" class="en_acc_meta">
                        <i class="fa fa-id-card-o" title="NIT"/> NIT: <t t-esc="record.en_partner_vat.raw_value"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Formulario del lead: panel de acreditación tipo "vista de importación" -->
    <record id="crm_lead_form_enetec_accred" model="ir.ui.view">
        <field name="name">crm.lead.form.enetec.accreditation</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Ocultar el ruido de ventas (no aplica a un proceso de acreditación) -->
            <xpath expr="//field[@name='expected_revenue']/ancestor::h2[1]" position="attributes">
                <attribute name="class" add="d-none" separator=" "/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="attributes">
                <attribute name="class" add="d-none" separator=" "/>
            </xpath>
            <xpath expr="//button[@name='action_sale_quotations_new']" position="attributes">
                <attribute name="invisible">en_party_role != False</attribute>
            </xpath>
            <xpath expr="//button[@name='action_set_won_rainbowman']" position="attributes">
                <attribute name="invisible">en_party_role != False</attribute>
            </xpath>
            <field name="date_deadline" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <field name="tag_ids" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>
            <!-- Panel de acreditación (banner + pipeline + datos + recorrido) arriba -->
            <xpath expr="//sheet/group[1]" position="before">
                <field name="en_timeline_html" nolabel="1" readonly="1"/>
            </xpath>
            <!-- Documentos de acreditación, siempre visibles, antes de las pestañas -->
            <xpath expr="//notebook" position="before">
                <separator string="Documentos de acreditación" invisible="not en_document_ids"/>
                <field name="en_document_ids" widget="many2many_binary" nolabel="1"
                       invisible="not en_document_ids" options="{'no_create': True}"/>
            </xpath>
            <!-- Pestaña con el resto de datos editables -->
            <xpath expr="//notebook" position="inside">
                <page string="Acreditación" name="en_accreditation">
                    <group>
                        <field name="en_party_role" invisible="1"/>
                        <field name="en_initiated_by"/>
                        <field name="en_inviter_partner_id"
                               invisible="en_initiated_by != 'counterparty'"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Lista de oportunidades: columna badge -->
    <record id="crm_case_tree_view_oppor_enetec" model="ir.ui.view">
        <field name="name">crm.lead.tree.enetec.party</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="en_party_role" widget="badge" optional="show"
                       decoration-info="en_party_role == 'client'"
                       decoration-warning="en_party_role == 'supplier'"/>
            </field>
        </field>
    </record>
</odoo>
