<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Ficha de revisión del documento -->
    <record id="view_pyxel_lead_document_form" model="ir.ui.view">
        <field name="name">pyxel.lead.document.form</field>
        <field name="model">pyxel.lead.document</field>
        <field name="arch" type="xml">
            <form string="Revisión de documento">
                <header>
                    <button name="action_lawyer_approve" type="object" string="Aprobar (legal)"
                            class="btn-primary" invisible="ai_state not in ('passed','doubt') or lawyer_state == 'approved'"/>
                    <button name="action_lawyer_reject" type="object" string="Rechazar (legal)"
                            invisible="ai_state not in ('passed','doubt') or lawyer_state == 'rejected'"/>
                    <button name="action_lawyer_reopen" type="object" string="Reabrir (legal)"
                            invisible="lawyer_state not in ('approved','rejected')"/>
                    <button name="action_commercial_approve" type="object" string="Aprobar (comercial)"
                            class="btn-primary" invisible="lawyer_state != 'approved' or commercial_state == 'approved'"/>
                    <button name="action_commercial_reject" type="object" string="Rechazar (comercial)"
                            invisible="lawyer_state != 'approved' or commercial_state == 'rejected'"/>
                    <button name="action_commercial_reopen" type="object" string="Reabrir (comercial)"
                            invisible="commercial_state not in ('approved','rejected')"/>
                    <button name="action_send_notes_email" type="object" string="Enviar notas por correo"
                            invisible="not attachment_id"/>
                    <field name="portal_state" widget="badge" decoration-success="portal_state == 'approved'"
                           decoration-warning="portal_state in ('in_review','validating')"
                           decoration-danger="portal_state == 'rejected'"/>
                </header>
                <sheet>
                    <div class="en-track en-track-backend">
                        <!-- Banner de estado -->
                        <div class="en-action success" invisible="portal_state != 'approved'">
                            <span class="ico"><i class="fa fa-check" title="Aprobado"/></span>
                            <span>Documento aprobado — los tres pasos están conformes.</span>
                        </div>
                        <div class="en-action warning" invisible="portal_state != 'rejected'">
                            <span class="ico"><i class="fa fa-times" title="Rechazado"/></span>
                            <span>Documento rechazado — el cliente debe reemplazarlo.</span>
                        </div>
                        <div class="en-action warning" invisible="portal_state not in ('in_review','validating','pending','optional')">
                            <span class="ico"><i class="fa fa-clock-o" title="En revisión"/></span>
                            <span>Documento en proceso de revisión.</span>
                        </div>

                        <div class="oe_title">
                            <h1><field name="document_label" readonly="1"/></h1>
                            <span class="text-muted"><field name="client_type" readonly="1"/></span>
                        </div>

                        <div class="row">
                            <div class="col-lg-7">
                                <div class="en-card">
                                    <h4>Documento subido</h4>
                                    <field name="attachment_id" invisible="1"/>
                                    <field name="document_file" filename="document_filename" widget="pdf_viewer"
                                           invisible="not attachment_id"/>
                                    <div invisible="attachment_id" class="text-muted">Sin documento subido.</div>
                                    <button name="action_view_document" type="object" string="Abrir en pestaña nueva"
                                            class="btn btn-link p-0 mt-2" invisible="not attachment_id"/>
                                </div>
                            </div>
                            <div class="col-lg-5">
                                <div class="en-card">
                                    <h4>1 · Análisis de la IA</h4>
                                    <group>
                                        <field name="ai_state" widget="badge" decoration-success="ai_state == 'passed'"
                                               decoration-warning="ai_state == 'doubt'" decoration-danger="ai_state == 'rejected'"
                                               decoration-info="ai_state == 'validating'"/>
                                        <field name="ai_confidence" widget="progressbar" readonly="1"/>
                                        <field name="ai_quality" widget="progressbar" readonly="1"/>
                                    </group>
                                    <div class="alert alert-danger mb-2" role="alert" invisible="ai_state != 'rejected'">
                                        La IA rechazó el documento.
                                    </div>
                                    <div class="alert alert-warning mb-2" role="alert" invisible="ai_state != 'doubt'">
                                        La IA lo marcó como dudoso.
                                    </div>
                                    <field name="ai_reason" readonly="1" invisible="not ai_reason"/>
                                    <field name="ai_extracted_data" readonly="1" invisible="not ai_extracted_data"/>
                                </div>
                                <div class="en-card" invisible="ai_state not in ('passed','doubt')">
                                    <h4>2 · Revisión de la abogada</h4>
                                    <group>
                                        <field name="lawyer_state" widget="badge" decoration-success="lawyer_state == 'approved'"
                                               decoration-danger="lawyer_state == 'rejected'"/>
                                        <field name="check_ok_count"/>
                                        <field name="check_total"/>
                                        <field name="lawyer_notes" placeholder="Notas internas (el cliente NO las ve)"/>
                                        <field name="lawyer_reason" placeholder="Motivo de rechazo (lo ve el cliente)"/>
                                    </group>
                                </div>
                                <div class="en-card" invisible="lawyer_state != 'approved'">
                                    <h4>3 · Revisión comercial</h4>
                                    <group>
                                        <field name="commercial_state" widget="badge" decoration-success="commercial_state == 'approved'"
                                               decoration-danger="commercial_state == 'rejected'"/>
                                        <field name="commercial_reason" placeholder="Motivo de rechazo (lo ve el cliente)"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                        <div class="en-card" invisible="check_total == 0">
                            <h4>Lista de validación — la abogada confirma cada punto</h4>
                            <field name="check_ids">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="severity" widget="badge"
                                           decoration-danger="severity == 'critico'" decoration-warning="severity == 'alto'"/>
                                    <field name="name" readonly="1"/>
                                    <field name="ai_status" string="IA" readonly="1" widget="badge"
                                           decoration-success="ai_status == 'ok'" decoration-danger="ai_status == 'fail'"
                                           decoration-info="ai_status == 'imagen'"/>
                                    <field name="detail" readonly="1"/>
                                    <field name="lawyer_ok" widget="boolean_toggle"/>
                                    <field name="lawyer_comment"/>
                                </tree>
                            </field>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Pestaña en el formulario del lead -->
    <record id="view_crm_lead_form_accreditation" model="ir.ui.view">
        <field name="name">crm.lead.form.accreditation.expediente</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Documentación de acreditación" invisible="accreditation_doc_count == 0">
                    <group>
                        <group>
                            <field name="accreditation_doc_count"/>
                            <field name="accreditation_approved_count"/>
                        </group>
                        <group>
                            <field name="accreditation_review_count"/>
                            <field name="accreditation_pending_count"/>
                        </group>
                    </group>
                    <field name="accreditation_document_ids" create="0" delete="0">
                        <tree create="0" delete="0">
                            <field name="document_label" readonly="1"/>
                            <field name="attachment_id" readonly="1"/>
                            <field name="ai_state" readonly="1" widget="badge"
                                   decoration-success="ai_state == 'passed'" decoration-warning="ai_state == 'doubt'"
                                   decoration-danger="ai_state == 'rejected'" decoration-info="ai_state == 'validating'"/>
                            <field name="ai_confidence" readonly="1"/>
                            <field name="lawyer_state" string="Abogada" readonly="1" widget="badge"
                                   decoration-success="lawyer_state == 'approved'" decoration-danger="lawyer_state == 'rejected'"/>
                            <field name="commercial_state" string="Comercial" readonly="1" widget="badge"
                                   decoration-success="commercial_state == 'approved'" decoration-danger="commercial_state == 'rejected'"/>
                            <field name="portal_state" string="Estado cliente" readonly="1" widget="badge"
                                   decoration-success="portal_state == 'approved'"
                                   decoration-warning="portal_state in ('in_review','validating')"
                                   decoration-danger="portal_state == 'rejected'"/>
                            <button name="action_open_review" type="object" string="Revisar"
                                    class="btn-link" invisible="not attachment_id"/>
                            <button name="action_view_document" type="object" string="Ver"
                                    class="btn-link" invisible="not attachment_id"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
