<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Layout de documentos de ENETEC. La cabecera (logo + datos) va DENTRO del
         cuerpo porque el motor PDF de este entorno no renderiza el header de
         página. Se aplica a TODOS los reportes (factura, venta, compra, etc.). -->
    <template id="external_layout_enetec">
        <div t-attf-class="article o_company_#{company.id}_layout"
             t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id"
             t-att-data-oe-lang="o and o.env.context.get('lang')">

            <!-- Cabecera de marca ENETEC (dentro del cuerpo) -->
            <div style="border-bottom:2px solid #185FA5; padding-bottom:10px; margin-bottom:16px; overflow:hidden;">
                <div style="float:left; max-width:55%;">
                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"
                         style="max-height:44px; max-width:240px;" alt="Logo"/>
                    <span t-else="" style="font-size:18px; font-weight:bold; color:#0C447C;"
                          t-field="company.name"/>
                </div>
                <div style="float:right; text-align:right; font-size:10.5px; line-height:1.5; color:#555;">
                    <div style="font-size:13px; font-weight:bold; color:#0C447C;" t-field="company.name"/>
                    <div t-if="company.company_registry">NIT <span t-field="company.company_registry"/></div>
                    <div t-if="company.street"><span t-field="company.street"/></div>
                    <div><span t-if="company.city" t-field="company.city"/><span t-if="company.country_id">, <span t-field="company.country_id"/></span></div>
                    <div t-if="company.phone">Tel. <span t-field="company.phone"/></div>
                    <div t-if="company.email"><span t-field="company.email"/></div>
                </div>
            </div>

            <!-- Dirección del destinatario (cliente/proveedor) -->
            <t t-call="web.address_layout"/>

            <!-- Contenido del documento (factura, venta, compra...) -->
            <t t-out="0"/>
        </div>

        <!-- Pie de página (este sí renderiza en el motor PDF) -->
        <div t-attf-class="footer o_company_#{company.id}_layout">
            <div class="text-center" style="border-top:1px solid #d0d0d0; padding-top:5px; font-size:9px; color:#888;">
                <div t-field="company.report_footer"/>
                <div t-if="report_type == 'pdf'">Página <span class="page"/> / <span class="topage"/></div>
            </div>
        </div>
    </template>

</odoo>
