<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <!-- Cron para sincronización de aeropuertos desde AirportsAPI -->
        <record id="ir_cron_airport_sync_weekly" model="ir.cron">
            <field name="name">Airport Sync Weekly</field>
            <field name="model_id" ref="transport_hub.model_transport_hub"/>
            <field name="state">code</field>
            <field name="code">model._sync_airports_from_api()</field>
            <field name="interval_type">weeks</field>
            <field name="interval_number">1</field>
            <field name="numbercall">-1</field> <!-- infinito -->
            <field name="doall" eval="False"/>
            <field name="user_id" eval="1"/> <!-- superusuario -->
            <field name="active" eval="True"/>
            <field name="nextcall" eval="'2025-08-10 00:00:00'"/> <!-- próximo domingo a las 12:00 AM -->
        </record>
    </data>
</odoo>
