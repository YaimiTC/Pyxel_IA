<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_importation_stage_tree" model="ir.ui.view">
            <field name="name">importation.stage.tree</field>
            <field name="model">importation.stage</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="fold"/>
                    <field name="is_final"/>
                    <field name="cannot_upload"/>
                </tree>
            </field>
        </record>

        <!-- Vista Form -->
        <record id="view_importation_stage_form" model="ir.ui.view">
            <field name="name">importation.stage.form</field>
            <field name="model">importation.stage</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                             <field name="sequence"/>
                             <field name="name"/>
                             <field name="description"/>
                             <field name="fold"/>
                             <field name="is_final"/>
                             <field name="cannot_upload"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <!-- Submenú de Configuración -->
        <menuitem id="menu_importation_config" name="Configuration"
                  parent="menu_importation_root" sequence="10"/>

        <!-- Acción para Importation Stages -->
        <record id="action_importation_stage" model="ir.actions.act_window">
            <field name="name">Importation Stages</field>
            <field name="res_model">importation.stage</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- Submenú que abre las etapas -->
        <menuitem id="menu_import_stage"
                  name="Importation Stages"
                  parent="menu_importation_config"
                  action="action_importation_stage"
                  sequence="10"/>

</odoo>