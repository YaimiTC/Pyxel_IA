<odoo>
    <data>
        <record id="view_import_wizard_form" model="ir.ui.view">
            <field name="name">import.wizard.form</field>
            <field name="model">import.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="file" widget="binary" filename="filename"/>
                        <field name="filename" invisible="1"/>
                    </group>
                    <footer>
                        <button name="import_data_from_excel" string="Import" type="object"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>

    <record id="action_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Container Data</field>
        <field name="res_model">import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_import_manager_root"
          name="Import Management"
          parent="menu_importation_root"
          sequence="10"/>

    <menuitem id="menu_import_wizard"
              name="Import container data"
              parent="menu_import_manager_root"
              action="action_import_wizard"
              sequence="1"/>

</odoo>