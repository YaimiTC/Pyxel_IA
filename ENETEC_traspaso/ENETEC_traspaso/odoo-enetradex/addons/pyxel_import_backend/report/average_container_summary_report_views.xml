<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
     <template id="average_container_summary_internal_layout" inherit_id="web.internal_layout" primary="True">
        <xpath expr="//div[hasclass('header')]" position="replace">
            <div class="header">
                 <div class="row">
                    <div class="col-2">
                        <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/>
                    </div>
                     <div class="col-5 offset-1 text-center">
                            <!-- Agrega aquí tu contenido de encabezado personalizad o -->
                            <span class="text-center; font-size:16px"> Reporte de Seguimiento de Contenedores</span>
                            <span> Desde: </span><span t-esc="start_date"/> <span>Hasta: </span><span t-esc="end_date"/>
                     </div>


                    <div class="col-2 offset-2 text-end">
                        <ul class="list-inline">
                            <li class="list-inline-item"><span class="page"/></li>
                            <li class="list-inline-item">/</li>
                            <li class="list-inline-item"><span class="topage"/></li>
                        </ul>
                    </div>
                </div>

            </div>
        </xpath>

    </template>
        <template id="container_summary_report_template">
            <t t-set="data_report_landscape" t-value="True"/>
             <t t-call="pyxel_fruxelimport.average_container_internal_layout">
                <t t-call="web.html_container">

                    <div class="page">

                                   <table style="width: 100%; table-layout:fixed; font-size:11px" class="table table-condensed">
                                                    <thead>
                                                     <tr>
                                                        <th class="text-left" scope="col" style="width: 3% !important; flex-wrap:wrap"><strong>No</strong></th>
                                                        <th class="text-left" scope="col" style="width: 7% !important; flex-wrap:wrap"><strong>Contenedor</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>(BL)/(AWB)</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Dato del cliente</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Teléfono del cliente</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Correo del cliente</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Condición de compra</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Fecha de Arribo</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Fecha de DM</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Fecha de Liberación</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Fecha de Precita</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Fecha de Cita</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Fecha de Extracción</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Fecha de Devolución</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Estado</strong></th>
                                                        <th class="text-center" scope="col" style="width: 10%;"><strong>Tiempo en estado (días)</strong></th>

                                                    </tr>
                                                   </thead>
                                                   <tbody>

                                                        <t t-set="index" t-value="0"/>
                                                        <tr t-foreach="docs" t-as="o">
                                                             <t t-set="index" t-value="index + 1"/>
                                                             <td class="text-left"  scope="col"><span  t-esc="index"/></td>
                                                             <td class="text-left" style="width: 7% !important; flex-wrap:wrap" scope="col"><span t-esc="o['container']"/></td>
                                                             <td class="text-left" scope="col"><span t-esc="o['x_studio_bill_of_landing']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_customers']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_phones']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_emails']"/></td>
                                                            <td class="text-center" scope="col"><span t-esc="o['x_studio_purchase_condition']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_arrival_date']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_dm_date']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_release_date']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_date_prior_to_appointment']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_appointment_date']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_extraction_date']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_return_date']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['x_studio_state']"/></td>
                                                             <td class="text-center" scope="col"><span t-esc="o['days_in_state']"/></td>
                                                        </tr>

                                                  </tbody>
                                   </table>
                    </div>
                </t>
            </t>
        </template>

        <record id="paperformat_container_summary" model="report.paperformat">
            <field name="name">Average container</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">30</field>
            <field name="margin_bottom">23</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">20</field>
            <field name="dpi">90</field>
        </record>


        <record id="report_average_container_summary" model="ir.actions.report">
            <field name="name">Average container summary</field>
            <field name="model">importation.load</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">pyxel_import_backend.container_summary_report_template</field>
            <field name="report_file">pyxel_import_backend.container_summary_report_template</field>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="pyxel_import_backend.paperformat_container_summary"/>
        </record>


    </data>
</odoo>