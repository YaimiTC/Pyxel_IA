<odoo>
    <data noupdate="1">
        <record id="ir_cron_check_incoming_emails" model="ir.cron">
            <field name="name">Check Incoming Emails</field>
            <field name="model_id" ref="model_mail_thread"/>
            <field name="state">code</field>
            <field name="code">model.check_incoming_emails()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
        </record>
    </data>
</odoo>
