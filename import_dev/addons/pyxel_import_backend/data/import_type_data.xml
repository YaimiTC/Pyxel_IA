<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record id="import_type_ocean" model="import.type">
            <field name="name">Ocean Freight</field>
            <field name="has_bl">True</field>
            <field name="has_packing_list">True</field>
            <field name="has_quality_certificate">True</field>
            <field name="has_export_certificate">True</field>
            <field name="has_origin_certificate">True</field>
            <field name="use_port">True</field>
            <field name="show_cargo_type">True</field>
            <field name="show_opening_date">True</field>
            <field name="show_arrival_date">True</field>
            <field name="show_release_date">True</field>
            <field name="show_extraction_date">True</field>
            <field name="show_shipping_company">True</field>
            <field name="show_transit_agency">True</field>
            <field name="show_volume">True</field>
            <field name="show_return_date">True</field>
        </record>
        <record id="import_type_air" model="import.type">
            <field name="name">Air Freight</field>
            <field name="has_awb">True</field>
            <field name="has_packing_list">True</field>
            <field name="has_quality_certificate">True</field>
            <field name="has_export_certificate">True</field>
            <field name="has_origin_certificate">True</field>
            <field name="use_airport">True</field>
            <field name="show_bulk">True</field>
            <field name="show_airline">True</field>
        </record>
        <record id="import_type_on_site" model="import.type">
            <field name="name">On Site</field>
            <field name="has_quality_certificate">True</field>
            <field name="has_export_certificate">True</field>
            <field name="has_origin_certificate">True</field>
            <field name="show_volume">True</field>
            <field name="show_bulk">True</field>
            <field name="show_return_date">True</field>
        </record>
    </data>
    <!-- noupdate="0": actualiza los flags de visibilidad en cada upgrade -->
    <data noupdate="0">
        <record id="import_type_ocean" model="import.type">
            <field name="show_shipping_company">True</field>
            <field name="show_transit_agency">True</field>
        </record>
    </data>
</odoo>
