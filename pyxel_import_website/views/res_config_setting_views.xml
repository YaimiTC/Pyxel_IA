<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit_x_model" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.x_model</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="90"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Imports" id="pyxel_import" string="Imports"
                         name="pyxel_import"
                         web_icon="pyxel_import_website/static/description/icon.png">
                         <block title="Planilla de Perfil de Proveedores">
                            <setting>
                                <field name="perfil_attachment_id"/>
                            </setting>
                            <div class="o_setting_help text-muted mt8">
                                Seleccione o cargue el adjunto que servirá como plantilla del perfil de proveedores para descarga.
                            </div>
                        </block>
                        
                         <block title="Planilla de Solicitud de Importación">
                            <setting>
                                <field name="solicitud_attachment_id"/>
                            </setting>
                            <div class="o_setting_help text-muted mt8">
                                Seleccione o cargue el adjunto que servirá como plantilla de la solicitud para descarga.
                            </div>
                        </block>
                        
                         <block title="Planilla de la Ficha de Cliente Estatal">
                            <setting>
                                <field name="ficha_cliente_estatal_attachment_id"/>
                            </setting>
                            <div class="o_setting_help text-muted mt8">
                                Seleccione o cargue el adjunto que servirá como plantilla de la ficha de cliente estatal para descarga.
                            </div>
                        </block>
                        
                         <block title="Planilla de la Ficha de Cliente FGNE o TCP">
                            <setting>
                                <field name="ficha_cliente_fgne_tcp_attachment_id"/>
                            </setting>
                            <div class="o_setting_help text-muted mt8">
                                Seleccione o cargue el adjunto que servirá como plantilla de la ficha de cliente FGNE o TCP para descarga.
                            </div>
                        </block>
                        
                         <block title="Planilla para Socio de Nacionalidad Cubana">
                            <setting>
                                <field name="cuban_partner_attachment_id"/>
                            </setting>
                            <div class="o_setting_help text-muted mt8">
                                Seleccione o cargue el adjunto que servirá como plantilla de socio con nacionalidad cubana para descarga.
                            </div>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>