<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="import_registration" name="Import registration">
            <t t-call="website.layout">
                <t t-set="logged_partner"
                    t-value="request.env['website.visitor']._get_visitor_from_request().partner_id" />
                <head>
                    <meta http-equiv="Cache-control" content="no-cache" />
                </head>
                <div id="wrap" class="oe_structure oe_empty">
                    <div class="col-lg-7 col-xl-6 me-lg-auto">
                        <!--<img
                        class="operation_banner_img"
                        t-att-src="'/pyxel_import_website/static/src/img/%s'%banner"/>-->

                    </div>
                    <section class="s_text_block  pb40 o_colored_level " data-snippet="s_text_block">
                        <div class="container s_allow_columns" string="margin-top:28px">
                            <div class="row">
                                <div class="col-lg-10 mt-4 mt-lg-0">
                                    <section class="s_website_form" data-vcss="001"
                                        data-snippet="s_website_form">
                                        <div class="container">
                                            <ol class="breadcrumb p-3 bg-transparent my-2">
                                                <!-- Home -->
                                                <li class="breadcrumb-item o_not_editable">
                                                    <a href="/">
                                                        <span>Inicio</span>
                                                    </a>
                                                </li>
                                                <li class="breadcrumb-item active">
                                                    <span
                                                        t-if="not crm_lead_exists and register_type not in ['accreditation_business', 'import']">Solicitar
                                                        Acreditación</span>
                                                    <span
                                                        t-if="register_type in ['accreditation_business']">Solicitar
                                                        Acreditación</span>
                                                    <span t-if="register_type in ['import']">Solicitar
                                                        Importación</span>
                                                </li>
                                            </ol>
                                            <form id="import_registration_form"
                                                action="/website/form/" method="post"
                                                enctype="multipart/form-data"
                                                class="o_mark_required" data-mark="*"
                                                data-model_name="sale.order"
                                                data-success-mode="redirect"
                                                data-success-page="/business-register-thanks"
                                                data-pre-fill="true">
                                                <input id="register_type" type="hidden"
                                                    name="register_type"
                                                    class="form-control s_website_form_input"
                                                    t-att-value="register_type" />
                                                <div class="s_website_form_rows s_col_no_bgcolor">
                                                    <div class="tab"
                                                        t-if="register_type in ['import']">

                                                        <!-- Hidden: lista de productos del nomenclador (usada por JS para construir los dropdowns) -->
                                                        <select id="productRequired" name="productRequired"
                                                            multiple="multiple"
                                                            style="display:none"
                                                            t-att-data-alimentos="alimentos_de_importacion"
                                                            t-att-data-alimentos-selected="productos_seleccionados_ids">
                                                        </select>
                                                        <!-- Hidden: filas en JSON para el preview y el submit -->
                                                        <input type="hidden" name="product_rows_json"
                                                            id="product_rows_json" value="[]" />
                                                        <input id="hiddenTestInput" type="hidden" value="1" />
                                                        <input type="hidden" id="fromNomenclador"
                                                            t-att-value="'1' if from_nomenclador else '0'" />
                                                        <!-- Tipos de envase disponibles para el JS -->
                                                        <input type="hidden" id="tipos_envase_json"
                                                            t-att-data-tipos="tipos_envase_json" />

                                                        <!-- Productos dinámicos (producto + cantidad + tipo envase por fila) -->
                                                        <div class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                                            data-name="Field" data-type="many2many">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px">
                                                                    <span class="s_website_form_label_content">Productos</span>
                                                                    <span class="s_website_form_mark"> *</span>
                                                                </label>
                                                                <div class="col-sm">
                                                                    <div id="product-rows-container" class="mb-2">
                                                                        <!-- Filas pre-seleccionadas desde nomenclador (renderizadas por servidor) -->
                                                                        <t t-foreach="initially_selected_products" t-as="sel_prod">
                                                                            <t t-set="row_data" t-value="saved_product_rows.get(str(sel_prod.id), {})"/>
                                                                            <div class="product-row d-flex align-items-center gap-1 mb-2">
                                                                                <select class="form-select product-row-product flex-grow-1" style="min-width:0">
                                                                                    <option value="">-- Seleccione producto --</option>
                                                                                    <t t-foreach="alimentos_list" t-as="p">
                                                                                        <option t-att-value="p.id" t-att-selected="'selected' if p.id == sel_prod.id else False">
                                                                                            <t t-out="p.name"/>
                                                                                        </option>
                                                                                    </t>
                                                                                </select>
                                                                                <input type="number" class="form-control product-row-cantidad" min="1" step="1" placeholder="Cant." style="width:75px;flex-shrink:0"
                                                                                    t-att-value="row_data.get('cantidad', '')"/>
                                                                                <select class="form-select product-row-tipo_envase" style="width:160px;flex-shrink:0">
                                                                                    <option value="">-- Tipo Envase --</option>
                                                                                    <t t-foreach="tipos_envase" t-as="te">
                                                                                        <option t-att-value="te.id"
                                                                                                t-att-selected="'selected' if str(te.id) == row_data.get('tipo_envase', '') else False">
                                                                                            <t t-out="te.name"/>
                                                                                        </option>
                                                                                    </t>
                                                                                </select>
                                                                                <button type="button" class="btn btn-outline-danger btn-sm btn-remove-row flex-shrink-0" title="Eliminar fila">×</button>
                                                                            </div>
                                                                        </t>
                                                                    </div>
                                                                    <div class="d-flex gap-2 mt-1 flex-wrap">
                                                                        <button type="button"
                                                                            id="btn-add-product-row"
                                                                            class="btn btn-outline-secondary btn-sm">
                                                                            + Agregar producto
                                                                        </button>
                                                                        <a href="/nomenclador?from=import_registration"
                                                                            class="btn btn-primary add-btn btn-sm"
                                                                            style="flex-shrink:0; white-space:nowrap;">
                                                                            <span class="btn-text">Buscar Producto</span>
                                                                        </a>
                                                                    </div>
                                                                    <span id="product-error"
                                                                        class="text-danger mt-1"
                                                                        style="display:none;">
                                                                        Debe seleccionar al menos un producto
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- Fecha de entrega deseada -->
                                                        <div data-name="Field"
                                                            class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                                            data-type="char">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px"
                                                                    for="commitment_date">
                                                                    <span class="s_website_form_label_content">Fecha de entrega deseada</span>
                                                                    <span class="s_website_form_mark">*</span>
                                                                </label>
                                                                <div class="col-sm">
                                                                    <input type="date"
                                                                        class="form-control s_website_form_input"
                                                                        name="commitment_date"
                                                                        id="commitment_date"
                                                                        t-att-value="saved_header.get('commitment_date', '')"
                                                                        required="" />
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- Forma de Pago -->
                                                        <div data-name="Field"
                                                            class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                                            data-type="many2one">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px"
                                                                    for="forma_pago">
                                                                    <span class="s_website_form_label_content">Forma de Pago</span>
                                                                    <span class="s_website_form_mark">*</span>
                                                                </label>
                                                                <div class="col-sm">
                                                                    <select
                                                                        class="form-select s_website_form_input"
                                                                        name="forma_pago"
                                                                        id="forma_pago"
                                                                        required="">
                                                                        <option value="">-- Seleccione --</option>
                                                                        <t t-foreach="payment_methods" t-as="pm">
                                                                            <option t-att-value="pm.id"
                                                                                t-att-selected="'selected' if str(pm.id) == saved_header.get('forma_pago', '') else False"
                                                                                t-out="pm.name"/>
                                                                        </t>
                                                                    </select>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- Presupuesto disponible -->
                                                        <div data-name="Field"
                                                            class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required"
                                                            data-type="float">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px"
                                                                    for="presupuesto_disponible">
                                                                    <span class="s_website_form_label_content">Presupuesto disponible (USD)</span>
                                                                    <span class="s_website_form_mark">*</span>
                                                                </label>
                                                                <div class="col-sm">
                                                                    <input type="number"
                                                                        class="form-control s_website_form_input"
                                                                        name="presupuesto_disponible"
                                                                        id="presupuesto_disponible"
                                                                        min="0"
                                                                        step="any"
                                                                        t-att-value="saved_header.get('presupuesto_disponible', '')"
                                                                        required="" />
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- Especificaciones -->
                                                        <div data-name="Field"
                                                            class="s_website_form_field mb-3 col-12 s_website_form_custom"
                                                            data-type="text">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px"
                                                                    for="note">
                                                                    <span class="s_website_form_label_content">Especificaciones</span>
                                                                </label>
                                                                <div class="col-sm">
                                                                    <textarea
                                                                        class="form-control s_website_form_input"
                                                                        name="note"
                                                                        id="note"
                                                                        rows="4"><t t-out="saved_header.get('note', '')"/></textarea>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <!-- Observaciones -->
                                                        <div data-name="Field"
                                                            class="s_website_form_field mb-3 col-12 s_website_form_custom"
                                                            data-type="text">
                                                            <div class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px"
                                                                    for="observaciones_solicitud">
                                                                    <span class="s_website_form_label_content">Observaciones</span>
                                                                </label>
                                                                <div class="col-sm">
                                                                    <textarea
                                                                        class="form-control s_website_form_input"
                                                                        name="observaciones_solicitud"
                                                                        id="observaciones_solicitud"
                                                                        rows="4"><t t-out="saved_header.get('observaciones_solicitud', '')"/></textarea>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div data-name="Field" name="solicitud"
                                                            class="s_website_form_field mb-0 col-12 s_website_form_custom s_website_form_required"
                                                            data-type="binary">
                                                            <div
                                                                class="row s_col_no_resize s_col_no_bgcolor py-3">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px"
                                                                    for="solicitud">
                                                                    <span
                                                                        class="s_website_form_label_content">Solicitud
                                                                        de oferta de compra</span>
                                                                    <span
                                                                        class="s_website_form_mark">
                                                                        *</span>
                                                                </label>
                                                                <div class="col-sm pl-5"
                                                                >
                                                                    <div
                                                                        name="solicitud_input_group"
                                                                        class="d-flex align-items-center w-100">
                                                                        <input type="file"
                                                                            class="form-control s_website_form_input flex-grow-1"
                                                                            name="solicitud"
                                                                            id="solicitud"
                                                                            accept=".xlsx,.xls,.pdf,.docx,.doc"
                                                                            data-max-files-number="20"
                                                                            data-max-file-size="30"
                                                                            data-fill-with="undefined"
                                                                            data-label=""
                                                                            required=""
                                                                            style="min-width: 0;" />

                                                                        <a id="solicitud"
                                                                            href="/descargar/solicitud"
                                                                            target="_blank"
                                                                            class="btn btn-primary add-btn"
                                                                            style="flex-shrink: 0; white-space: nowrap; margin-left: 0 !important;">
                                                                            <span class="btn-text">Descargar
                                                                                Plantilla</span>
                                                                        </a>
                                                                    </div>
                                                                    <div
                                                                        class="s_website_form_field_description small form-text text-muted">
                                                                        Descargue la plantilla,
                                                                        llénela y súbala aquí.
                                                                    </div>
                                                                    <span id="solicitud_error"
                                                                        style="color:red; display:none;">El
                                                                        documento adjuntado debe ser
                                                                        del mismo tipo que el
                                                                        archivo descargado.</span>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div data-name="Field" name="load_products"
                                                            class="s_website_form_field mb-3 col-12 s_website_form_custom"
                                                            data-type="binary">
                                                            <div
                                                                class="row s_col_no_resize s_col_no_bgcolor">
                                                                <label
                                                                    class="col-form-label col-sm-auto s_website_form_label"
                                                                    style="width: 200px"
                                                                    for="load_products">
                                                                    <span
                                                                        class="s_website_form_label_content">Carga
                                                                        de productos</span>
                                                                </label>
                                                                <div class="col-sm pl-5"
                                                                    >
                                                                    <div
                                                                        name="load_products_input_group"
                                                                        class="d-flex align-items-center w-100">
                                                                        <input type="file"
                                                                            class="form-control s_website_form_input flex-grow-1"
                                                                            name="load_products"
                                                                            id="load_products"
                                                                            accept=".xlsx"
                                                                            data-max-files-number="1"
                                                                            data-max-file-size="6"
                                                                            data-fill-with="undefined"
                                                                            data-label=""
                                                                            style="min-width: 0;" />

                                                                        <a id="load_products"
                                                                            href="/descargar/load_products"
                                                                            target="_blank"
                                                                            class="btn btn-primary add-btn"
                                                                            style="flex-shrink: 0; white-space: nowrap; margin-left: 0 !important;">
                                                                            <span class="btn-text">Descargar
                                                                                Plantilla</span>
                                                                        </a>
                                                                    </div>
                                                                    <div
                                                                        class="s_website_form_field_description small form-text text-muted">
                                                                        Descargue la plantilla,
                                                                        llénela y súbala aquí.
                                                                    </div>
                                                                    <span id="load_products_error"
                                                                        style="color:red; display:none;">El
                                                                        documento adjuntado debe ser
                                                                        del mismo tipo que el
                                                                        archivo descargado.</span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div style="float:right; margin-right:3%">
                                                        <button type="button"
                                                            class="btn btn-outline-info rounded-pill px-3"
                                                            id="prevBtn">
                                                            Anterior
                                                        </button>
                                                        <button type="button"
                                                            class="btn btn-outline-info rounded-pill px-3"
                                                            id="nextBtn">
                                                            Siguiente
                                                        </button>

                                                        <a href="#" id="btn-preview" role="button"
                                                            class="btn btn-outline-secondary rounded-pill px-4 d-none">
                                                            Previsualizar
                                                        </a>
                                                        <a href="#" id="button-submit" role="button"
                                                            class="btn btn-outline-info rounded-pill px-4 s_website_form_send register_business_button d-none">
                                                            Solicitar servicio
                                                        </a>
                                                        <span id="s_website_form_result" />
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </section>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </t>
        </template>
    </data>
</odoo>
