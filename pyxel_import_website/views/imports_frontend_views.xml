<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="importations_list" name="Imports">
        <t t-call="website.layout">
            <owl-component name="pyxel_import_website.ImportationsTable" />
        </t>
    </template>
    <template id="importation_view" name="import record">
        <t t-call="website.layout">
            <div id="o_website_record_page wrap">
                <div class="container-fluid px-4">
                    <ol t-if="listing" class="breadcrumb bg-transparent p-0 my-2">
                        <!-- Home -->
                        <li class="breadcrumb-item o_not_editable">
                            <a href="/my/home">
                                <span>Mi Cuenta</span>
                            </a>
                        </li>
                        <li class="breadcrumb-item o_not_editable">
                            <a t-att-href="listing['href']">
                                <span t-out="listing['name']" />
                            </a>
                        </li>
                        <li class="breadcrumb-item active">
                            <span t-field="record.display_name" />
                        </li>
                    </ol>
                    <div
                        class="d-flex flex-row my-4 flex-wrap align-items-top justify-content-between">
                        <div class="col-lg-2 col-sm-2 pl-0">
                            <div class="d-flex justify-content-start align-items-left gap-0 mb-1">
                                <img class="o_portal_contact_img rounded o_object_fit_cover"
                                    t-att-src="image_data_uri(record.provider_id.avatar_128)"
                                    alt="Contact"
                                    width="70" />
                                <div class="d-flex flex-column justify-content-center">
                                    <h4 class="mb-0" t-out="record.provider_id.name" />
                                    <p class="mb-0 text-muted"
                                        t-out="record.provider_id.company_name" />
                                </div>
                            </div>
                            <div class="card-text d-flex flex-column flex-grow-1">
                                <div class="o_inner_group grid col-lg-12">
                                    <div>
                                        <span>BL:</span>
                                        <span
                                            t-esc="record.purchase_condition_number or record.display_name" />
                                    </div>
                                    <div>
                                        <span>Proveedor:</span>
                                        <span t-field="record.provider_id" />
                                    </div>
                                    <div>
                                        <span>Origen:</span>
                                        <span t-field="record.country_origin_id" />
                                    </div>
                                    <div>
                                        <span>Estado:</span>
                                        <span t-field="record.stage_id" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-10 mt-lg-10 col-sm-9 px-3">
                            <div id="informations">
                                <!--<div
                                class="row">-->
                                <div class="mb-3 mt-3 px-0 col-12 o_field_statusbar">
                                    <div class="o_statusbar_status" role="radiogroup">
                                        <t t-set="current_stage_id" t-value="record.stage_id.id"/>
                                        <t t-set="all_stages" t-value="record.stage_id._name and env[record.stage_id._name].search([])"/>
                                        <div class="mb-3 mt-3 px-0 col-12 o_field_statusbar">
                                            <div class="o_statusbar_status" role="radiogroup">
                                                <t t-foreach="all_stages" t-as="stage">
                                                    <button type="button"
                                                        t-att-disabled="stage.id == current_stage_id"
                                                        t-attf-class="btn btn-sm p-1 boton_secondary_import o_arrow_button #{'o_arrow_button_current' if stage.id == current_stage_id else ''}"
                                                        t-esc="stage.name"/>
                                                </t>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!--</div>    -->
                                <t t-set="containers"
                                    t-value="[i for i in record.load_tracking_ids]" />
                                <div class="row" id="po_date">
                                    <div class="mb-3 col-12">
                                        <strong>
                                            <h4>Datos de la operación</h4>
                                        </strong>
                                        <a t-att-href="'/update_files/%s' % record.id"> <t t-out="upload_file_link_label"/> </a>
                                        <!--<span
                                        t-field="order.date_order" t-options="{&quot;widget&quot;:
                                        &quot;date&quot;}"/>-->
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-lg-12">
                                        <!--  <strong class="d-block mb-1">Desde:</strong> -->
                                        <address t-field="record.provider_id"
                                            t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;], &quot;no_marker&quot;: True}" />
                                        <div
                                            t-att-class="'d-inline' if record.estimated_start_date else 'd-none'">
                                            <strong>Fecha de inicio de operación:</strong>
                                            <span class="ms-1" t-field="record.estimated_start_date"
                                                t-options="{&quot;widget&quot;: &quot;date&quot;}" />
                                        </div>
                                        <div t-att-class="'d-inline' if record.port else 'd-none'"
                                            style="margin-left: 10px;">
                                            <strong>Puerto de Origen:</strong>
                                            <span class="ms-1" t-field="record.port" />
                                        </div>
                                        <div t-att-class="'d-inline' if containers else 'd-none'"
                                            style="margin-left: 10px;">
                                            <strong>Naviera:</strong>
                                            <t t-set="shipping_company" t-value="'---'" />
                                            <t t-foreach="containers" t-as="container">
                                                <t t-if="container.shipping_company">
                                                    <t t-set="shipping_company"
                                                        t-value="container.shipping_company" />
                                                    <t t-break="" />
                                                </t>
                                            </t>
                                            <span class="ms-1" t-esc="shipping_company" />
                                        </div>
                                    </div>
                                </div>
                                <!-- <t t-set="containers" t-value="[i for i in
                                record.load_tracking_ids]"/> -->
                                <div t-if="not containers" class="row" t-cache="false">
                                    <div class="col">
                                        <strong class="d-block mb-1">Ordenes de compra: <t
                                                t-esc="len(record.purchase_order_ids)" />
                                        </strong>
                                    </div>
                                    <t t-foreach="record.purchase_order_ids" t-as="purchase">
                                        <section id="details" style="page-break-inside: auto;"
                                            class="mt10">
                                            <div class="table-responsive">
                                                <table class="table table-sm" id="container_table">
                                                    <thead class="bg-100">
                                                        <tr>
                                                            <th class="text-start">Producto</th>
                                                            <th class="text-end">Cantidad</th>
                                                            <th class="text-end">Precio</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="purchase_tbody">
                                                        <t t-set="current_subtotal" t-value="0" />
                                                        <t t-foreach="purchase.sudo().order_line"
                                                            t-as="line">
                                                            <t t-set="current_subtotal"
                                                                t-value="current_subtotal + line.price_subtotal" />
                                                            <tr
                                                                t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic text-break' if line.display_type == 'line_note' else ''">
                                                                <t t-if="not line.display_type">
                                                                    <td id="product_name">
                                                                        <t
                                                                            t-if="line.sudo().product_id.image_1024">
                                                                            <img
                                                                                t-att-src="image_data_uri(line.sudo().product_id.image_48)"
                                                                                alt="Product"
                                                                                class="d-none d-lg-inline" />
                                                                        </t>
                                                                        <span t-field="line.name" />
                                                                    </td>
                                                                    <td class="text-end">
                                                                        <div id="quote_qty">
                                                                            <span
                                                                                t-field="line.product_qty" />
                                                                            <span
                                                                                t-field="line.product_uom"
                                                                                groups="uom.group_uom" />
                                                                        </div>
                                                                    </td>
                                                                    <td
                                                                        t-attf-class="text-end {{ 'd-none d-sm-table-cell' if report_type == 'html' else '' }}">
                                                                        <div
                                                                            t-field="line.price_subtotal"
                                                                            class="text-end" />
                                                                    </td>
                                                                </t>
                                                                <t
                                                                    t-if="line.display_type == 'line_section'">
                                                                    <td colspan="99">
                                                                        <span t-field="line.name" />
                                                                    </td>
                                                                    <t t-set="current_section"
                                                                        t-value="line" />
                                                                    <t t-set="current_subtotal"
                                                                        t-value="0" />
                                                                </t>
                                                                <t
                                                                    t-if="line.display_type == 'line_note'">
                                                                    <td colspan="99">
                                                                        <span t-field="line.name" />
                                                                    </td>
                                                                </t>
                                                            </tr>
                                                            <t
                                                                t-if="current_section and (line_last or order.order_line[line_index+1].display_type == 'line_section')">
                                                                <tr class="is-subtotal text-end">
                                                                    <td colspan="99">
                                                                        <strong class="mr16">
                                                                            Subtotal</strong>
                                                                        <span
                                                                            t-esc="current_subtotal"
                                                                            t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: order.currency_id}" />
                                                                    </td>
                                                                </tr>
                                                            </t>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <!--<div
                                            id="total" t-if="order.state in ['purchase', 'done']"
                                            class="row"-->
                                            <!--     name="total" style="page-break-inside: avoid;">-->
                                            <!--    <div t-attf-class="#{'col-4' if report_type !=
                                            'html' else 'col-sm-7 col-md-5'} ms-auto">-->
                                            <!--        <t
                                            t-call="purchase.purchase_order_portal_content_totals_table"/>-->
                                            <!--    </div>-->
                                            <!--</div>-->
                                        </section>
                                    </t>
                                </div>
                                <div t-if="containers" class="row" t-cache="false">
                                    <div class="col">
                                        <strong class="d-block mb-1">Cantidad de contenedores: <t
                                                t-esc="len(containers)" />
                                        </strong>
                                    </div>
                                    <!-- Nueva fila con las fechas -->
                                    <div class="row">
                                        <div class="col">
                                            <strong class="d-block mb-1">Fecha de Arribo: <t
                                                    t-set="arrival_date" t-value="'Por arribar'" />
                                                <t
                                                    t-foreach="containers" t-as="container">
                                                    <t t-if="container.arrival_date">
                                                        <t t-set="arrival_date"
                                                            t-value="container.arrival_date" />
                                                        <t t-break="" />
                                                    </t>
                                                </t>
                                                <t
                                                    t-esc="arrival_date" />
                                            </strong>
                                        </div>
                                        <div class="col">
                                            <strong class="d-block mb-1">Fecha de Extracción: <t
                                                    t-set="extraction_date" t-value="'Por extraer'" />
                                                <t
                                                    t-foreach="containers" t-as="container">
                                                    <t t-if="container.extraction_date">
                                                        <t t-set="extraction_date"
                                                            t-value="container.extraction_date" />
                                                        <t t-break="" />
                                                    </t>
                                                </t>
                                                <t
                                                    t-esc="extraction_date" />
                                            </strong>
                                        </div>
                                        <div class="col">
                                            <strong class="d-block mb-1">Fecha de Devolución: <t
                                                    t-set="return_date" t-value="'Por devolver'" />
                                                <t
                                                    t-foreach="containers" t-as="container">
                                                    <t t-if="container.return_date">
                                                        <t t-set="return_date"
                                                            t-value="container.return_date" />
                                                        <t t-break="" />
                                                    </t>
                                                </t>
                                                <t
                                                    t-esc="return_date" />
                                            </strong>
                                        </div>
                                    </div>
                                    <t t-foreach="containers" t-as="container">
                                        <section t-cache="False" id="details"
                                            style="page-break-inside: auto;"
                                            class="mt10">
                                            <div class="row mb-2">
                                                <t t-set="type_load_label"
                                                    t-value="{'refrigerated':'Refigerada','grouped':'Agrupada','dry':'Seca'}" />
                                                <div class="col-lg-4 mt-lg-4 col-sm-8">
                                                    <span>
                                                        <h7 style="font-weight: bold;">Contenedor:</h7>
                                                        <t t-esc="container.name" />
                                                    </span>
                                                    <br />
                                                    <span>
                                                        <h7 style="font-weight: bold;">Arribo:</h7>
                                                        <t t-esc="container.arrival_date" />
                                                    </span>
                                                </div>
                                                <div class="col-lg-4 mt-lg-4 col-sm-8">
                                                    <span>
                                                        <h7 style="font-weight: bold;">Peso (kg):</h7>
                                                        <t t-esc="container.weight" />
                                                    </span>
                                                    <br />
                                                    <span>
                                                        <h7 style="font-weight: bold;">Tamaño
                                                            (pies):</h7>
                                                        <t t-esc="container.size" />
                                                    </span>
                                                </div>
                                                <t t-if="container != False">
                                                    <div class="col-lg-4 mt-lg-4 col-sm-8">
                                                        <t t-if="container.cargo_type != False">
                                                            <span>
                                                                <h7 style="font-weight: bold;">Tipo
                                                                    de carga:</h7>
                                                                <t
                                                                    t-esc="type_load_label[container.cargo_type]" />
                                                            </span>
                                                        </t>
                                                        <t
                                                            t-if="container.total_cargo_line != False">
                                                            <br />
                                                            <span>
                                                                <h7 style="font-weight: bold;">
                                                                    Importe:</h7>
                                                                <t
                                                                    t-esc="container.total_cargo_line" />
                                                                <t
                                                                    t-esc="container.currency_id.name" />
                                                            </span>
                                                        </t>
                                                    </div>
                                                </t>
                                            </div>
                                            <div class="table-responsive">
                                                <table class="table table-sm" id="container_table">
                                                    <thead class="bg-100">
                                                        <tr>
                                                            <th class="text-start">Producto</th>
                                                            <th class="text-end">Cantidad</th>
                                                            <th class="text-end">Precio</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="purchase_tbody">
                                                        <t t-set="current_subtotal" t-value="0" />
                                                        <t t-foreach="container.purchase_order_ids"
                                                            t-as="purchase_order">
                                                            <t t-foreach="purchase_order.order_line"
                                                                t-as="line">
                                                                <t t-set="current_subtotal"
                                                                    t-value="current_subtotal + line.price_subtotal" />
                                                                <tr
                                                                    t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic text-break' if line.display_type == 'line_note' else ''">
                                                                    <t t-if="not line.display_type">
                                                                        <td id="product_name">
                                                                            <t
                                                                                t-if="line.sudo().product_id.image_1024">
                                                                                <img
                                                                                    t-att-src="image_data_uri(line.sudo().product_id.image_48)"
                                                                                    alt="Product"
                                                                                    class="d-none d-lg-inline" />
                                                                            </t>
                                                                            <span
                                                                                t-field="line.name" />
                                                                        </td>
                                                                        <td class="text-end">
                                                                            <div id="quote_qty">
                                                                                <span
                                                                                    t-field="line.product_qty" />
                                                                                <span
                                                                                    t-field="line.product_uom"
                                                                                    groups="uom.group_uom" />
                                                                            </div>
                                                                        </td>
                                                                        <td
                                                                            t-attf-class="text-end {{ 'd-none d-sm-table-cell' if report_type == 'html' else '' }}">
                                                                            <div
                                                                                t-field="line.price_subtotal"
                                                                                class="text-end" />
                                                                        </td>
                                                                    </t>
                                                                    <t
                                                                        t-if="line.display_type == 'line_section'">
                                                                        <td colspan="99">
                                                                            <span
                                                                                t-field="line.name" />
                                                                        </td>
                                                                        <t t-set="current_section"
                                                                            t-value="line" />
                                                                        <t t-set="current_subtotal"
                                                                            t-value="0" />
                                                                    </t>
                                                                    <t
                                                                        t-if="line.display_type == 'line_note'">
                                                                        <td colspan="99">
                                                                            <span
                                                                                t-field="line.name" />
                                                                        </td>
                                                                    </t>
                                                                </tr>
                                                                <t
                                                                    t-if="current_section and (line_last or order.order_line[line_index+1].display_type == 'line_section')">
                                                                    <tr class="is-subtotal text-end">
                                                                        <td colspan="99">
                                                                            <strong class="mr16">
                                                                                Subtotal</strong>
                                                                            <span
                                                                                t-esc="current_subtotal"
                                                                                t-options="{&quot;widget&quot;: &quot;monetary&quot;, &quot;display_currency&quot;: order.currency_id}" />
                                                                        </td>
                                                                    </tr>
                                                                </t>
                                                            </t>
                                                        </t>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <!--<div
                                            id="total" t-if="order.state in ['purchase', 'done']"
                                            class="row"-->
                                            <!--     name="total" style="page-break-inside: avoid;">-->
                                            <!--    <div t-attf-class="#{'col-4' if report_type !=
                                            'html' else 'col-sm-7 col-md-5'} ms-auto">-->
                                            <!--        <t
                                            t-call="purchase.purchase_order_portal_content_totals_table"/>-->
                                            <!--    </div>-->
                                            <!--</div>-->
                                        </section>
                                    </t>
                                    <div id="a">
                                        <h4>Comuníquese con nosotros</h4>
                                        <t t-call="portal.message_thread">
                                            <t t-set="object" t-value="record" />
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <hr />
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>