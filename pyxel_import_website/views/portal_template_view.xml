<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="portal_my_home_inherit" inherit_id="portal.portal_my_home" priority="1000">
        <xpath expr="//div[@id='portal_alert_category']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>

        <xpath expr="//div[@id='portal_vendor_category']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>

        <xpath expr="//div[@id='portal_common_category']" position="replace">
            <div class="o_portal_category row g-2 mt-3" id="portal_common_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/pyxel_import_website/static/src/custom_icons/facturas.png'"/>
                    <t t-set="title">
                        <t t-esc="new_invoices_count or ''"/>
                        Facturas
                    </t>
                    <t t-set="text">Vea sus facturas</t>
                    <t t-set="url" t-value="'/my/invoices'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/pyxel_import_website/static/src/custom_icons/importaciones.png'"/>
                    <t t-set="title">
                        <t t-esc="new_importaciones_count or ''"/>
                        Importaciones
                    </t>
                    <t t-set="text">Vea sus importaciones</t>
                    <t t-set="url" t-value="'/model/imports'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-if="accreditation_count" t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/pyxel_import_website/static/src/custom_icons/solicitudes.png'"/>
                    <t t-set="title">
                        Mi acreditación
                    </t>
                    <t t-set="text">Documentos de su expediente</t>
                    <t t-set="url" t-value="'/my/acreditacion'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </div>
        </xpath>
    </template>

    <template id="portal_my_accreditation" name="Mi acreditación">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Mi expediente de acreditación</t>
            </t>

            <t t-if="not documents">
                <div class="alert alert-info mt-3" role="alert">
                    Aún no tiene un expediente de acreditación activo.
                </div>
            </t>

            <t t-if="documents">
                <!-- Resumen -->
                <div class="row g-2 mt-1 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body py-2">
                                <h4 class="mb-0" t-esc="lead.accreditation_doc_count"/>
                                <small class="text-muted">Requeridos</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body py-2">
                                <h4 class="mb-0 text-success" t-esc="lead.accreditation_approved_count"/>
                                <small class="text-muted">Aprobados</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body py-2">
                                <h4 class="mb-0 text-warning" t-esc="lead.accreditation_review_count"/>
                                <small class="text-muted">En revisión</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="card text-center h-100">
                            <div class="card-body py-2">
                                <h4 class="mb-0 text-danger" t-esc="lead.accreditation_pending_count"/>
                                <small class="text-muted">Pendientes</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Documentos -->
                <t t-foreach="documents" t-as="doc">
                    <div class="card mb-2">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="mb-0" t-esc="doc.document_label"/>
                                <t t-set="st" t-value="doc.portal_state"/>
                                <span t-if="st == 'approved'" class="badge bg-success">Aprobado</span>
                                <span t-if="st == 'in_review'" class="badge bg-warning text-dark">En revisión</span>
                                <span t-if="st == 'validating'" class="badge bg-info text-dark">Validando…</span>
                                <span t-if="st == 'rejected'" class="badge bg-danger">Rechazado</span>
                                <span t-if="st == 'pending'" class="badge bg-secondary">Pendiente</span>
                                <span t-if="st == 'optional'" class="badge bg-light text-muted">Opcional</span>
                            </div>

                            <t t-if="doc.portal_state == 'rejected' and doc.portal_reason">
                                <div class="alert alert-danger py-2 px-3 mb-2" style="font-size:0.875rem;">
                                    <i class="fa fa-exclamation-triangle me-1"/>
                                    <t t-esc="doc.portal_reason"/>
                                </div>
                            </t>
                            <t t-if="doc.portal_state == 'in_review'">
                                <div class="alert alert-light py-2 px-3 mb-2" style="font-size:0.875rem;">
                                    <i class="fa fa-robot me-1"/>
                                    La validación automática fue superada. Ahora lo revisa nuestro equipo.
                                </div>
                            </t>

                            <!-- Decisión comercial visible al cliente: solo cuando aprobado -->
                            <t t-if="doc.portal_state == 'approved'">
                                <div class="alert alert-success py-2 px-3 mb-2" style="font-size:0.875rem;">
                                    <i class="fa fa-check-circle me-1"/>
                                    Documento aprobado por nuestro equipo. No requiere cambios.
                                </div>
                            </t>

                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div class="text-muted" style="font-size:0.85rem;">
                                    <t t-if="doc.attachment_id">
                                        <i class="fa fa-file-pdf-o me-1"/>
                                        <t t-esc="doc.attachment_id.name"/>
                                        <t t-if="doc.upload_date">
                                            · Subido el <span t-field="doc.upload_date" t-options='{"format": "dd/MM/yyyy"}'/>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <span class="fst-italic">Ningún archivo subido</span>
                                    </t>
                                </div>

                                <div class="d-flex gap-2">
                                    <!-- Descargar -->
                                    <a t-if="doc.attachment_id"
                                       t-attf-href="/my/acreditacion/download/{{ doc.id }}"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fa fa-download me-1"/>Descargar
                                    </a>

                                    <!-- Eliminar: solo si NO está aprobado ni en revisión (aprobado = solo ver) -->
                                    <form t-if="doc.attachment_id and doc.portal_state not in ('in_review', 'approved')"
                                          t-attf-action="/my/acreditacion/delete/{{ doc.id }}"
                                          method="post" class="d-inline">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="fa fa-trash me-1"/>Eliminar
                                        </button>
                                    </form>

                                    <!-- Subir / Resubir -->
                                    <t t-if="doc.portal_state in ('pending', 'rejected', 'optional')">
                                        <form t-attf-action="/my/acreditacion/upload/{{ doc.id }}"
                                              method="post" enctype="multipart/form-data"
                                              class="d-inline d-flex gap-1">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="file" name="document" accept="application/pdf"
                                                   class="form-control form-control-sm" style="max-width:200px;" required="required"/>
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                <i class="fa fa-upload me-1"/>
                                                <t t-if="doc.portal_state == 'rejected'">Subir otro</t>
                                                <t t-else="">Subir</t>
                                            </button>
                                        </form>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="portal_side_content_inherit" inherit_id="portal.side_content">
        <xpath expr="//div[@class='o_portal_my_details']" position="inside">
            <t t-if="contract_status != False">
                <div>
                    <br/>
                    <span t-esc="contract_status"/>
                    <t t-if="days_in_process != 'False'">
                    <br/>
                        <span>Días en proceso: <t t-out="days_in_process"/></span>
                    </t>
                </div>
            </t>
        </xpath>
    </template>

    <template id="sale_portal_my_home_inherit" inherit_id="sale.portal_my_home_sale" priority="1000">
        <xpath expr="//div[@id='portal_alert_category']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <xpath expr="//div[@id='portal_client_category']" position="replace">
            <div class="o_portal_category row g-2 mt-3" id="portal_client_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/pyxel_import_website/static/src/custom_icons/pedidos.png'"/>
                    <t t-set="title">
                        <t t-esc="new_quotations_count or ''"/>
                        Pedidos
                    </t>
                    <t t-set="text">Vea sus cotizaciones</t>
                    <t t-set="url" t-value="'/my/quotes'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/pyxel_import_website/static/src/custom_icons/solicitudes.png'"/>
                    <t t-set="title">
                        <t t-esc="new_orders_count or ''"/>
                        Solicitudes
                    </t>
                    <t t-set="text">Vea sus órdenes</t>
                    <t t-set="url" t-value="'/my/orders'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </div>
        </xpath>
    </template>

    <record id="payment.portal_my_home_payment" model="ir.ui.view">
        <field name="active">False</field>
    </record>
    <record id="account.portal_my_home_invoice" model="ir.ui.view">
        <field name="active">False</field>
    </record>
    <record id="purchase.portal_my_home_purchase" model="ir.ui.view">
        <field name="active">False</field>
    </record>
    <record id="project.portal_my_home" model="ir.ui.view">
        <field name="active">False</field>
    </record>
<!--    <record id="knowledge.portal_my_home_knowledge" model="ir.ui.view">-->
<!--        <field name="active">False</field>-->
<!--    </record>-->

    <!-- Comentadas. Nuevo Flujo -->

    <template id="portal_my_quotations_inherit" inherit_id="sale.portal_my_quotations">
        <xpath expr="//t[@t-foreach='quotations']/tr" position="attributes">
            <attribute name="class">
                <t t-if="not quotation.quotation_supplier_approved">bg-info</t>
            </attribute>
        </xpath>
        <xpath expr="//t[@t-foreach='quotations']/tr" position="inside">
            <td class="text-end">
                <t t-if="quotation.state == 'sent' and not quotation.is_expired">
                    <span class="badge badge-primary">Pendiente</span>
                </t>
                <t t-if="quotation.is_expired">
                    <span class="badge badge-warning">Vencida</span>
                </t>
                <t t-if="quotation.state == 'sale'">
                    <span class="badge badge-success">Aceptada</span>
                </t>
                <t t-if="quotation.state == 'cancel'">
                    <span class="badge badge-danger">Cancelada</span>
                </t>
            </td>
        </xpath>
    </template>

    <template id="marketplace_user_needed">
        <t t-call="website.layout">
            <div class="alert alert-info text-center" role="alert">
                <h1>Atención:</h1>
                <h3>
                    El acceso a la tienda solo está permitido a clientes acreditados.
                </h3>
                <br/>
                <p>Por favor
                    <a href="/web/login">
                        <span class="badge badge-success">Inicie Sesión</span>
                    </a>
                    o cree su
                    <a href="/web/signup">
                        <span class="badge badge-success">Usuario</span>
                    </a>
                </p>
            </div>
        </t>
    </template>

    <template id="marketplace_onboard_needed">
        <t t-call="website.layout">
            <div class="alert alert-info text-center" role="alert">
                <h1>Atención:</h1>
                <h3>
                    El acceso a la tienda solo está permitido a clientes acreditados.
                </h3>
                <br/>
                <p>Por favor inicie su proceso de
                    <a href="/business-register?type=accreditation">
                        <span class="badge badge-success">Acreditación</span>
                    </a>
                </p>
            </div>
        </t>
    </template>

    <template id="services_onboard_needed">
        <t t-call="website.layout">
            <div class="alert alert-info text-center" role="alert">
                <h1>Atención:</h1>
                <h3>
                    El acceso a nuestros servicios solo está permitido a clientes acreditados y con un contrato activo.
                </h3>
                <br/>
                <p>Si aun no lo ha hecho, por favor inicie su proceso de
                    <a href="/business-register?type=accreditation">
                        <span class="badge badge-success">Acreditación</span>
                    </a>.
                </p>
            </div>
        </t>
    </template>
</odoo>
