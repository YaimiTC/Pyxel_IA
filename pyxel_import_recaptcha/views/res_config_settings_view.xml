<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_recaptcha" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.recaptcha</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
             <xpath expr="//form" position="inside">
                <div class="app_settings_block" string="Google reCAPTCHA Settings">
                    <h2>Google reCAPTCHA</h2>
                    <div class="row mt16">
                        <div class="col-6 o_setting_left_pane">
                            <label for="recaptcha_site_key"/>
                        </div>
                        <div class="col-6 o_setting_right_pane">
                            <field name="recaptcha_site_key"/>
                        </div>
                    </div>
                    <div class="row mt16">
                        <div class="col-6 o_setting_left_pane">
                            <label for="recaptcha_secret_key"/>
                        </div>
                        <div class="col-6 o_setting_right_pane">
                            <field name="recaptcha_secret_key"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
